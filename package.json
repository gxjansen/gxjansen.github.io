{
  "name": "atlas",
  "type": "module",
  "version": "0.1.1",
  "scripts": {
    "dev": "astro dev",
    "dev:netlify": "netlify dev",
    "build": "node scripts/standard-site-publish.mjs && astro build && node scripts/test-robots.js",
    "preview": "astro build --mode preview",
    "production": "astro build --mode production",
    "astro": "astro",
    "check-dark-mode": "node scripts/check-dark-mode.js",
    "fix-dark-mode": "node scripts/fix-dark-mode.js",
    "fix-dark-mode:dry": "node scripts/fix-dark-mode.js --dry-run",
    "test": "vitest",
    "test:a11y": "playwright test",
    "test:a11y:inventory": "A11Y_INVENTORY=1 playwright test",
    "test:robots": "node scripts/test-robots.js",
    "validate-content": "node scripts/validate-content.js",
    "bluesky:link": "node scripts/bluesky-link.mjs",
    "standard-site:setup": "node scripts/standard-site-setup.mjs",
    "standard-site:publish": "node scripts/standard-site-publish.mjs",
    "check:trailing-slashes": "node scripts/check-trailing-slashes.js",
    "optimize-images": "node scripts/optimize-images.mjs",
    "format:check": "prettier --check \"src/**/*.{astro,ts,tsx,js,jsx,mjs,css,md,mdx}\"",
    "format": "prettier --write \"src/**/*.{astro,ts,tsx,js,jsx,mjs,css,md,mdx}\"",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astro-community/astro-embed-youtube": "^0.5.10",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/netlify": "^7.0.10",
    "@astrojs/react": "^5.0.5",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@atproto/api": "^0.20.0",
    "@iconify-json/tabler": "^1.2.35",
    "@netlify/blobs": "^10.7.8",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@types/date-fns": "^2.6.3",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "altcha-lib": "^1.4.1",
    "animejs": "^4.4.1",
    "astro": "^6.3.7",
    "astro-auto-import": "^0.5.1",
    "astro-embed": "^0.13.0",
    "astro-icon": "^1.1.5",
    "autoprefixer": "^10.4.27",
    "bluesky-comments": "^0.13.1",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "date-fns": "^4.2.1",
    "fast-xml-parser": "^5.8.0",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.3",
    "node-html-parser": "^7.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sanitize-html": "^2.17.4",
    "sass": "^1.97.3",
    "satori": "^0.26.0",
    "svg-country-flags": "^1.2.10",
    "swiper": "^12.1.2",
    "tailwindcss": "^4.3.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.2",
    "baseline-browser-mapping": "^2.10.31",
    "fs-extra": "^11.3.5",
    "jsdom": "^27.4.0",
    "lightningcss": "^1.31.1",
    "node-html-markdown": "^2.0.0",
    "prettier-plugin-astro": "^0.14.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svgo": "^2.8.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.4",
    "lightningcss-linux-x64-gnu": "^1.30.1"
  },
  "overrides": {
    "sharp": "^0.33.0",
    "lodash": "^4.17.23",
    "@isaacs/brace-expansion": "^5.0.1",
    "tar": "^7.5.9",
    "devalue": "^5.6.3",
    "ajv": "^8.18.0"
  }
}
