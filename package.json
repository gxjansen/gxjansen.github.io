{
  "name": "atlas",
  "type": "module",
  "version": "0.1.1",
  "scripts": {
    "dev": "astro dev",
    "dev:netlify": "netlify dev",
    "build": "node scripts/standard-site-publish.mjs && astro build && node scripts/test-robots.js",
    "preview": "astro build --mode preview",
    "production": "astro build --mode production",
    "astro": "astro",
    "check-dark-mode": "node scripts/check-dark-mode.js",
    "fix-dark-mode": "node scripts/fix-dark-mode.js",
    "fix-dark-mode:dry": "node scripts/fix-dark-mode.js --dry-run",
    "test": "vitest",
    "test:robots": "node scripts/test-robots.js",
    "validate-content": "node scripts/validate-content.js",
    "bluesky:link": "node scripts/bluesky-link.mjs",
    "standard-site:setup": "node scripts/standard-site-setup.mjs",
    "standard-site:publish": "node scripts/standard-site-publish.mjs",
    "check:trailing-slashes": "node scripts/check-trailing-slashes.js",
    "format:check": "prettier --check \"src/**/*.{astro,ts,tsx,js,jsx,mjs,css,md,mdx}\"",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astro-community/astro-embed-youtube": "^0.5.10",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/netlify": "^7.0.8",
    "@astrojs/react": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@atproto/api": "^0.19.11",
    "@iconify-json/tabler": "^1.2.33",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/dom": "^10.4.1",
    "@types/animejs": "^3.1.13",
    "@types/date-fns": "^2.6.3",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "altcha-lib": "^1.4.1",
    "animejs": "^3.2.2",
    "astro": "^6.1.9",
    "astro-auto-import": "^0.5.1",
    "astro-embed": "^0.13.0",
    "astro-icon": "^1.1.5",
    "astro-seo": "^0.8.4",
    "autoprefixer": "^10.5.0",
    "bluesky-comments": "^0.13.1",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "date-fns": "^4.1.0",
    "fast-xml-parser": "^5.4.1",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.6",
    "node-html-parser": "^7.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sanitize-html": "^2.17.3",
    "sass": "^1.99.0",
    "svg-country-flags": "^1.2.10",
    "swiper": "^12.1.3",
    "tailwindcss": "^3.4.19",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@fullhuman/postcss-purgecss": "^7.0.2",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.2",
    "baseline-browser-mapping": "^2.10.0",
    "fs-extra": "^11.3.3",
    "jsdom": "^27.4.0",
    "lightningcss": "^1.31.1",
    "prettier-plugin-astro": "^0.14.0",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "svgo": "2.8.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.2",
    "lightningcss-linux-x64-gnu": "^1.30.1"
  },
  "overrides": {
    "sharp": "^0.33.0",
    "lodash": "^4.17.23",
    "@isaacs/brace-expansion": "^5.0.1",
    "tar": "^7.5.9",
    "devalue": "^5.6.3",
    "ajv": "^8.18.0"
  }
