---
import { type CollectionEntry } from "astro:content";

// component imports
import Seo from "@components/Seo/Seo.astro";

// data
import standardSiteConfig from "@config/standardSite.json";
import { CONFIG } from "../config"; // Use .env for indexing
import type { EventData, PresentationData, CommunityData } from "@js/jsonLD";

export interface Props {
  type?:
    | "blog"
    | "general"
    | "event"
    | "eventList"
    | "presentation"
    | "presentationList"
    | "communities"
    | undefined;
  title: string;
  description: string;
  image?: ImageMetadata;
  postFrontmatter?: CollectionEntry<"post">["data"];
  authors?: CollectionEntry<"authors">[];
  noindex?: boolean;
  // Event detail
  event?: EventData;
  // Events index
  events?: EventData[];
  // Presentation detail
  presentation?: PresentationData;
  presentationSlug?: string;
  // Presentations index
  presentations?: PresentationData[];
  presentationSlugs?: string[];
  // Communities page
  communities?: CommunityData[];
}

const {
  type = "general",
  title,
  description,
  image,
  authors,
  postFrontmatter,
  event,
  events,
  presentation,
  presentationSlug,
  presentations,
  presentationSlugs,
  communities,
} = Astro.props as Props;
// Use the environment variable to determine noindex
const noindex = !CONFIG.ALLOW_INDEXING;
---

<meta charset="utf-8" />
<!-- Content Security Policy is now handled via Netlify headers for better security -->

<meta
  name="viewport"
  content="width=device-width, initial-scale=1.0, viewport-fit=cover"
/>
<meta name="color-scheme" content="dark light" />
<meta
  name="theme-color"
  media="(prefers-color-scheme: light)"
  content="#faf4ed"
/>
<meta
  name="theme-color"
  media="(prefers-color-scheme: dark)"
  content="#191724"
/>

<!-- Accessibility meta tags -->
<meta name="format-detection" content="telephone=no" />
<meta name="format-detection" content="date=no" />
<meta name="format-detection" content="address=no" />
<meta name="format-detection" content="email=no" />

<!-- Font loading — self-hosted (no Google CDN at runtime).
     Display: Schibsted Grotesk · Body: Atkinson Hyperlegible Next · Hand: LiebeHeide.
     @font-face rules generated by scripts/fetch-redesign-fonts.mjs. -->
<link rel="stylesheet" href="/fonts/redesign-fonts.css" />

<!-- Warm up the CDN that serves the live activity-feed images (homepage). -->
<link rel="preconnect" href="https://cdn.bsky.app" crossorigin />
<link rel="dns-prefetch" href="https://cdn.bsky.app" />

<!-- Preload the two critical latin faces (body + display, normal weight). -->
<link
  rel="preload"
  href="/fonts/atkinson-hyperlegible-next/atkinson-hyperlegible-next-03.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
<link
  rel="preload"
  href="/fonts/schibsted-grotesk/schibsted-grotesk-03.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>

<!-- Favicons. I store these in public/favicons. Wherever you store them in the public folder is what you need these href's to match -->
<link rel="icon" href="/favicons/favicon.ico" />
<!-- Below is generated from https://realfavicongenerator.net/ -->
<link
  rel="apple-touch-icon"
  sizes="180x180"
  href="/favicons/apple-touch-icon.png"
/>
<link
  rel="icon"
  type="image/png"
  sizes="32x32"
  href="/favicons/favicon-32x32.png"
/>
<link
  rel="icon"
  type="image/png"
  sizes="16x16"
  href="/favicons/favicon-16x16.png"
/>
<link rel="manifest" href="/favicons/site.webmanifest" />
<link rel="mask-icon" href="/favicons/safari-pinned-tab.svg" color="#31748f" />
<link rel="shortcut icon" href="/favicons/favicon.ico" />
<meta name="msapplication-TileColor" content="#faf4ed" />
<meta name="msapplication-config" content="/favicons/browserconfig.xml" />
<!-- end favicons -->

<!-- other -->
<meta name="generator" content={Astro.generator} />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  title="Guido X Jansen"
  href="/rss.xml"
/>
<link rel="me" href="https://sifa.id/p/gui.do" />
<link rel="me" href="https://bsky.app/profile/gui.do" />

{/* Standard.site document verification (AT Protocol long-form publishing) */}
{
  standardSiteConfig.enabled &&
    type === "blog" &&
    (() => {
      const slug = Astro.url.pathname
        .replace(/^\/post\//, "")
        .replace(/\/$/, "");
      const href = `at://${standardSiteConfig.did}/site.standard.document/${slug}`;
      return <link rel="site.standard.document" href={href} />;
    })()
}

<!-- Theme change setup. Run early to eliminate Flash of inAccurate coloR Theme (FART) -->
<script is:inline>
  // Mark JS as available before paint so reveal-on-scroll can hide its start
  // state (it degrades to fully visible when this class is absent).
  document.documentElement.classList.add("js");

  function initTheme() {
    const prefersDark = window.matchMedia("(prefers-color-scheme: dark)");
    let colorTheme = localStorage.getItem("colorTheme");

    function applyTheme(theme) {
      if (theme === "dark") {
        document.documentElement.classList.add("dark");
        document.documentElement.style.colorScheme = "dark";
      } else {
        document.documentElement.classList.remove("dark");
        document.documentElement.style.colorScheme = "light";
      }
    }

    // Initial theme setup
    if (!colorTheme) {
      colorTheme = prefersDark.matches ? "dark" : "light";
      localStorage.setItem("colorTheme", colorTheme);
    }
    applyTheme(colorTheme);

    // Listen for system theme changes
    prefersDark.addEventListener("change", (e) => {
      if (!localStorage.getItem("colorTheme")) {
        const newTheme = e.matches ? "dark" : "light";
        applyTheme(newTheme);
        localStorage.setItem("colorTheme", newTheme);
      }
    });
  }

  // runs on initial page load
  initTheme();
</script>

<Seo
  type={type as any}
  title={title}
  description={description}
  image={image}
  authors={authors}
  postFrontmatter={postFrontmatter}
  noindex={noindex}
  event={event as any}
  events={events as any}
  presentation={presentation as any}
  slug={presentationSlug as any}
  presentations={presentations as any}
  slugs={presentationSlugs as any}
  communities={communities as any}
/>

{
  /*
  Umami Analytics — disabled pending a public endpoint.
  The current host only resolves on the homelab network, so the script
  fails for off-network visitors (and spams Chrome console errors).
  Restore once Umami is reachable via a public hostname.
*/
}
{
  /* Self-hosted, cookieless Umami analytics. Production only — never in dev. */
  import.meta.env.PROD && (
    <>
      <link rel="dns-prefetch" href="https://u.a11y.nl" />
      <link rel="preconnect" href="https://u.a11y.nl" crossorigin />
      <script
        is:inline
        async
        defer
        src="https://u.a11y.nl/script.js"
        data-website-id="c5cf1235-9d9d-4543-b0be-2acc2551d8f5"
      />
    </>
  )
}
