---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";

const podcasts = [
  {
    icon: "sheep",
    title: "Sheeptank",
    text: "A lighthearted, fast-paced format: one interesting business case (pitched by the sheep) and a final verdict (from the wolves).",
    href: "https://sheeptank.transistor.fm/",
  },
  {
    icon: "tabler/outline/a-b",
    title: "CRO.CAFE",
    text: "Conversion rate optimization and business experimentation, with episodes in English, Dutch, Spanish and German.",
    href: "https://www.cro.cafe",
  },
  {
    icon: "tabler/outline/friends",
    title: "Spryker Community",
    text: "Stories from the community, sharing insights and best practices.",
    href: "https://www.youtube.com/results?search_query=spryker",
  },
];
---

<BaseLayout
  title="Guido's Podcasts"
  description="The podcasts Guido X Jansen hosts and produces: Sheeptank, CRO.CAFE and more. Over 250 episodes on community, experimentation and business."
>
  <div class="home podcasts-page">
    <section
      class="relative z-10 pt-[clamp(4.5rem,9vw,7rem)] pb-[clamp(2rem,5vw,4rem)]"
    >
      <div class="max-w-[60ch]">
        <span class="hand-note">on the mic</span>
        <h1
          class="font-display mt-1 mb-4 text-[clamp(2.2rem,5vw,3.2rem)] leading-[1.05] font-black tracking-[-0.03em]"
        >
          Podcasts I host &amp; produce
        </h1>
        <p class="text-base-600 dark:text-base-400 text-lg leading-relaxed">
          Podcasting is a great way to learn, share, and get to know people.
          I've published over 250 episodes across a few different shows.
        </p>
      </div>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          podcasts.map((p) => (
            <a
              href={p.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group bg-base-50 dark:bg-base-900 border-base-200 dark:border-base-800 reveal flex flex-col rounded-2xl border p-6 transition hover:-translate-y-0.5 hover:shadow-lg"
            >
              <div class="bg-primary-600/10 text-primary-600 dark:bg-primary-400/10 dark:text-primary-400 mb-4 flex size-12 items-center justify-center rounded-xl">
                <Icon name={p.icon} class="size-6" aria-hidden="true" />
              </div>
              <h2 class="font-display group-hover:text-primary-600 dark:group-hover:text-primary-400 text-[1.2rem] font-extrabold transition">
                {p.title}
              </h2>
              <p class="text-base-600 dark:text-base-400 mt-2 text-[0.95rem] leading-relaxed">
                {p.text}
              </p>
              <span class="text-primary-600 dark:text-primary-400 font-display mt-4 inline-flex items-center gap-1.5 text-sm font-bold">
                Listen <span aria-hidden="true">→</span>
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="relative z-10 pb-[clamp(3rem,7vw,5.5rem)]">
      <div class="sec-head">
        <div>
          <span class="hand-note">fresh from the feed</span>
          <h2>Recent episodes</h2>
        </div>
      </div>

      <div id="podcast-feed-container">
        <div class="text-center">
          <div
            class="border-primary-500 inline-block h-8 w-8 animate-spin rounded-full border-t-2 border-b-2"
          >
          </div>
          <p class="text-base-600 dark:text-base-400 mt-4">
            Loading podcast episodes...
          </p>
        </div>
      </div>
    </section>
  </div>

  <script>
    async function loadPodcastFeed() {
      const container = document.getElementById("podcast-feed-container");
      if (!container) return;

      try {
        // In development, use the Netlify Dev server URL from the environment
        const baseUrl = import.meta.env.DEV
          ? `http://localhost:${import.meta.env.NETLIFY_PORT || "8888"}`
          : "";
        const response = await fetch(
          `${baseUrl}/.netlify/functions/getPodcastFeeds`,
        );
        if (!response.ok) {
          const errorData = await response.json().catch(() => ({}));
          throw new Error(
            errorData.error || `HTTP error! status: ${response.status}`,
          );
        }

        const episodes = await response.json();

        // Filter out episodes without valid links
        const validEpisodes = episodes.filter(
          (episode: { link: string; title: string }) =>
            episode.link &&
            episode.link.startsWith("https://share.transistor.fm/"),
        );

        if (validEpisodes.length === 0) {
          container.innerHTML = `
            <div class="text-center p-8 bg-base-100 dark:bg-base-900 rounded-2xl">
              <p class="text-base-700 dark:text-base-300">No podcast episodes are currently available.</p>
              <p class="text-base-600 dark:text-base-400 mt-2">Please check back later or visit the podcasts directly:</p>
              <div class="mt-4 space-y-2">
                <a href="https://sheeptank.transistor.fm/" class="text-primary-600 dark:text-primary-400 hover:underline block font-semibold">Sheeptank</a>
                <a href="https://www.cro.cafe" class="text-primary-600 dark:text-primary-400 hover:underline block font-semibold">CRO.CAFE</a>
              </div>
            </div>
          `;
          return;
        }

        // Replace loading spinner with episodes
        container.innerHTML =
          `<div class="grid gap-6 sm:grid-cols-2">` +
          validEpisodes
            .map(
              (episode: { link: string; title: string }) => `
          <div class="w-full bg-base-100 dark:bg-base-900 border border-base-200 dark:border-base-800 rounded-2xl overflow-hidden">
            <iframe
              width="100%"
              height="180"
              frameborder="no"
              scrolling="no"
              seamless
              src="${episode.link}"
              title="${episode.title}"
              loading="lazy"
              allow="encrypted-media"
            ></iframe>
          </div>
        `,
            )
            .join("") +
          `</div>`;
      } catch (error) {
        console.error("Error loading podcast feed:", error);
        container.innerHTML = `
          <div class="text-center p-8 bg-base-100 dark:bg-base-900 rounded-2xl">
            <p class="text-base-700 dark:text-base-300 mb-4">${
              (error as Error).message ===
              "Timeout while fetching podcast feeds"
                ? "The podcast feeds are taking longer than usual to load. Please try again in a moment."
                : "We're having trouble loading the podcast feeds right now. Please try again later."
            }</p>
            <p class="text-base-600 dark:text-base-400">In the meantime, you can visit the podcasts directly:</p>
            <div class="mt-4 space-y-2">
              <a href="https://sheeptank.transistor.fm/" class="text-primary-600 dark:text-primary-400 hover:underline block font-semibold">Sheeptank</a>
              <a href="https://www.cro.cafe" class="text-primary-600 dark:text-primary-400 hover:underline block font-semibold">CRO.CAFE</a>
            </div>
          </div>
        `;
      }
    }

    // Load feed when page loads
    loadPodcastFeed();

    // Reload feed when navigating back to the page
    document.addEventListener("astro:page-load", loadPodcastFeed);
  </script>
</BaseLayout>
