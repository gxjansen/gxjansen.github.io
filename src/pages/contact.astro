---
import BaseLayout from "@layouts/BaseLayout.astro";
import SocialCards from "@components/SocialCards/SocialCards.astro";

const CAL = "https://app.cal.eu/gxjansen/30min";
---

<BaseLayout
  title="Contact & booking"
  description="Get in touch with Guido X Jansen: book a call, send a DM, or invite me to speak at your event."
>
  <div class="home contact-page">
    <section
      class="relative z-10 pt-[clamp(4.5rem,9vw,7rem)] pb-[clamp(3rem,7vw,5.5rem)]"
    >
      <div class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">Get in touch</span>
        <h1
          class="font-display mt-2 mb-4 text-[clamp(2.2rem,5vw,3.2rem)] leading-[1.05] font-black tracking-[-0.03em]"
        >
          Let's talk
        </h1>
        <p class="text-base-600 dark:text-base-400 text-lg leading-relaxed">
          Want me to speak at your event, advise your team, or just trade notes
          on community and experimentation? Book a slot or send me a DM,
          whatever's easiest.
        </p>
        <div class="mt-7 flex flex-wrap justify-center gap-3">
          <a
            href={CAL}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-primary-600 hover:bg-primary-700 dark:bg-primary-500 dark:hover:bg-primary-400 font-display inline-flex items-center gap-1.5 rounded-full px-6 py-3 text-sm font-bold text-white transition"
          >
            Book 30 minutes <span aria-hidden="true">→</span>
          </a>
          <a
            href="/retainer/"
            class="border-base-300 hover:border-primary-600 dark:border-base-700 dark:hover:border-primary-400 font-display inline-flex items-center gap-1.5 rounded-full border px-6 py-3 text-sm font-bold transition"
          >
            Work with me
          </a>
        </div>
      </div>

      <div class="mt-14">
        <div class="mx-auto mb-6 max-w-2xl text-center">
          <span class="hand-note">or find me here</span>
        </div>
        <SocialCards />
      </div>
    </section>
  </div>
</BaseLayout>
