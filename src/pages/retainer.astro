              </li>

              <li class="relative">
                <span
                  class="border-primary-600 dark:border-primary-400 text-primary-600 dark:text-primary-400 bg-base-50 dark:bg-base-900 absolute -left-[4.25rem] flex h-12 w-12 items-center justify-center rounded-full border-2 text-sm font-bold ring-4 ring-[var(--color-background)] dark:ring-[var(--color-background-dark)]"
                  aria-hidden="true"
                >
                  ×6
