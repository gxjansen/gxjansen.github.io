---
// layout
import BaseLayout from "@layouts/BaseLayout.astro";

// components
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

// images
import speakerImage from "@images/headshot/08.02.2022_Spryker_CEO_0278.jpg";
import headshot1 from "@images/headshot/08.02.2022_Spryker_CEO_0278.jpg";
import headshot2 from "@images/headshot/08.02.2022_Spryker_CEO_2636.jpg";
import headshot3 from "@images/headshot/08.02.2022_Spryker_CEO_2669.jpg";

import { yearsBuilding, countryCount, talksCount } from "@data/siteStats";

const card =
  "bg-base-50 dark:bg-base-900 border-base-200 dark:border-base-800 rounded-2xl border p-6";

// Section overview cards
const overview = [
  {
    icon: "tabler/outline/file-text",
    title: "Rider Kit",
    desc: "Technical and logistical requirements",
    href: "#talk-format",
  },
  {
    icon: "tabler/outline/user",
    title: "Bio Format",
    desc: "Speaker biography and credentials",
    href: "#biography",
  },
  {
    icon: "tabler/outline/currency-euro",
    title: "Fee",
    desc: "Speaking fees and expenses",
    href: "#fee",
  },
  {
    icon: "tabler/outline/quote",
    title: "Testimonials",
    desc: "What others say about my talks",
    href: "#testimonials",
  },
  {
    icon: "tabler/outline/map-pin",
    title: "Travel & Accommodation",
    desc: "Logistics and requirements",
    href: "#travel",
  },
  {
    icon: "tabler/outline/device-tv",
    title: "AV/Tech Requirements",
    desc: "Technical setup needed",
    href: "#av-tech",
  },
  {
    icon: "tabler/outline/news",
    title: "Content for Your Marketing",
    desc: "Materials to promote the event",
    href: "#marketing",
  },
  {
    icon: "tabler/outline/sparkles",
    title: "And the Rest...",
    desc: "Additional information and details",
    href: "#headshots",
  },
];

// Testimonials
const testimonials = [
  {
    initial: "E",
    quote:
      "Guido is an excellent public speaker. Whether it's a workshop, a conference talk, or a meetup, he always manages to bring energy and knowledge to his presentations.",
    name: "Erin Weigel",
    role: "Advisor, ABsmartly",
  },
  {
    initial: "A",
    quote: "Give him a stage and the audience will love him!",
    name: "Alex Franke",
    role: "EVP, Spryker",
  },
  {
    initial: "J",
    quote:
      "His session was extremely well received by a diverse audience of web development professionals. Guido's ability to communicate complex topics in a clear and engaging manner made his talk a highlight of the event.",
    name: "John O'Connor",
    role: "Development Inspector, Charles White Limited",
  },
  {
    initial: "T",
    quote:
      "I attended Guido's CRO session at Growth Tribe and I was mind-blown. He's articulate, knowledgeable, and uses real examples and frameworks that you can actually apply.",
    name: "Thomas Paris",
    role: "Director of Demand Generation, Posh",
  },
  {
    initial: "M",
    quote:
      "Guido brought his 'Persuasive eCommerce' topic to our meetup in Jakarta and the audience loved it. Very engaging speaker with deep practical knowledge.",
    name: "Muliadi Jeo",
    role: "Founder and Director, ICUBE",
  },
  {
    initial: "F",
    quote:
      "Guido has a unique combination of knowledge about psychology, experimentation, and e-commerce that makes his talks both insightful and highly practical.",
    name: "Florian Gendrault",
    role: "CEO, Alleo",
  },
  {
    initial: "R",
    quote:
      "Guido brings a unique blend of technical expertise and practical insights. His presentation style is engaging and the content is always relevant to our audience.",
    name: "Rob Janssen",
    role: "Event Director, Digital Analytics Congress",
  },
  {
    initial: "K",
    quote:
      "Working with Guido was a pleasure. He understood our audience needs and delivered content that was both educational and actionable. Our attendees loved it!",
    name: "Koen Verhagen",
    role: "Conference Organizer, Meet Magento",
  },
  {
    initial: "S",
    quote:
      "Guido's expertise in conversion optimization and his ability to translate complex concepts into practical advice made his session one of the most valuable at our event.",
    name: "Sandra de Vries",
    role: "Head of Programming, How to Web",
  },
];

// Featured presentations — lead with what I talk about now (community, AI,
// psychology), not the legacy e-commerce catalogue.
const presentations = [
  {
    img: "/images/presentations/presentation-53d766b9.webp",
    title: "The Future of Community: Where Psychology, Tech and AI Collide",
    desc: "Where community building, psychology and AI meet, and what to start experimenting with right now.",
    duration: "40 minutes",
    href: "/presentations/the-future-of-community-where-psychology-tech-and-ai-collide/",
  },
  {
    img: "/images/presentations/guido-speaking.jpg",
    title: "AI/n8n workflow automation for techies",
    desc: "A hands-on demo of automating real work with AI and n8n, for teams who don't know where to start.",
    duration: "50 minute demo",
    href: "/presentations/n8n-ai-workflow-automation/",
  },
  {
    img: "/images/presentations/presentation-998768a1.jpeg",
    title: "Data Driven Decisions meets Psychology",
    desc: "Pairing experimentation with how people actually behave, so the data leads to better decisions.",
    duration: "30-90 minutes",
    href: "/presentations/data-driven-decisions-meets-psychology/",
  },
];

// Headshots
const headshots = [
  {
    src: headshot1,
    href: "/images/headshot/08.02.2022_Spryker_CEO_0278.jpg",
  },
  {
    src: headshot2,
    href: "/images/headshot/08.02.2022_Spryker_CEO_2636.jpg",
  },
  {
    src: headshot3,
    href: "/images/headshot/08.02.2022_Spryker_CEO_2669.jpg",
  },
];
---

<BaseLayout
  title="Speaking | Guido X Jansen"
  description="Everything organizers typically want to know about me. Speaking terms, requirements, and booking information."
  noindex={true}
>
  <div class="home speaker-page">
    <!-- ============ HERO ============ -->
    <section
      class="relative z-10 pt-[clamp(4.5rem,9vw,7rem)] pb-[clamp(2rem,5vw,4rem)]"
    >
      <div class="mx-auto max-w-3xl text-center">
        <div class="sec-head justify-center text-center">
          <div>
            <span class="hand-note">speaker information</span>
            <h1
              class="font-display text-[clamp(2.2rem,5vw,3.2rem)] leading-[1.1] font-black tracking-[-0.03em]"
            >
              Speaking at your event
            </h1>
          </div>
        </div>
        <p
          class="text-base-700 dark:text-base-300 text-[clamp(1.1rem,2vw,1.35rem)] leading-relaxed"
        >
          Everything organizers typically want to know about me
        </p>
        <p
          class="text-base-600 dark:text-base-400 mx-auto mt-4 max-w-2xl text-lg leading-relaxed"
        >
          Community Builder with {yearsBuilding}+ years creating technical
          ecosystems. {talksCount} talks across {countryCount} countries. If you're
          interested in having me speak at your event, you'll find all the information
          you need below.
        </p>
      </div>
    </section>

    <!-- ============ WHAT YOU CAN FIND ============ -->
    <section class="relative z-10 py-[clamp(3rem,7vw,5.5rem)]">
      <div class="mb-10 text-center">
        <span class="hand-note">on this page</span>
        <h2
          class="font-display text-[clamp(1.9rem,3.6vw,2.7rem)] leading-[1.1] font-black tracking-[-0.03em]"
        >
          What you can find on this page:
        </h2>
      </div>

      <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
        {
          overview.map((item) => (
            <a
              href={item.href}
              class={`${card} group reveal hover:border-primary-600/40 dark:hover:border-primary-400/40 block text-center no-underline transition hover:-translate-y-0.5 hover:shadow-lg`}
            >
              <div class="text-primary-600 dark:text-primary-400 mx-auto mb-3 flex size-12 items-center justify-center">
                <Icon name={item.icon} class="size-7" aria-hidden="true" />
              </div>
              <h3 class="font-display text-[1rem] leading-snug font-bold">
                {item.title}
              </h3>
              <p class="text-base-600 dark:text-base-400 mt-1.5 text-sm leading-relaxed">
                {item.desc}
              </p>
            </a>
          ))
        }
      </div>
    </section>

    <!-- ============ BIO ============ -->
    <section id="bio" class="relative z-10 py-[clamp(3rem,7vw,5.5rem)]">
      <div
        class="grid items-center gap-[clamp(1.5rem,4vw,3rem)] md:grid-cols-2"
      >
        <div>
          <Image
            src={speakerImage}
            alt="Guido Jansen speaking at a conference"
            class="w-full rounded-2xl"
            widths={[400, 800, 1200]}
            sizes="(min-width: 768px) 50vw, 100vw"
            quality={90}
            format="webp"
          />
        </div>
        <div>
          <div class="sec-head">
            <div>
              <span class="hand-note">a quick intro</span>
              <h2 class="leading-[1.1]">About the Speaker Guido X Jansen</h2>
            </div>
          </div>
          <div
            class="prose dark:prose-invert text-base-700 dark:text-base-300 max-w-none space-y-4 text-[1.05rem] leading-relaxed"
          >
            <p>
              I'm a Community Builder who turns technical ecosystems into real
              business growth. With {yearsBuilding}+ years at the intersection
              of psychology and technology, I've built community functions from
              zero multiple times.
            </p>
            <p>
              My cognitive psychology background shapes how I approach community
              work. Not by predicting how developers will behave, but by testing
              assumptions and watching what they actually do, because the one
              thing psychology reliably teaches is that you can't reliably
              predict people.
            </p>
            <p>
              I've presented at {talksCount} talks across {countryCount}
              countries on topics including composable commerce, community building,
              and digital psychology.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ AM I THE RIGHT FIT ============ -->
    <section id="fit" class="relative z-10 py-[clamp(3rem,7vw,5.5rem)]">
      <div class="mx-auto max-w-3xl text-center">
        <div class="sec-head justify-center text-center">
          <div>
            <span class="hand-note">before you ask</span>
            <h2 class="leading-[1.1]">Am I the right fit?</h2>
          </div>
        </div>
        <div
          class="prose dark:prose-invert text-base-600 dark:text-base-400 mx-auto max-w-none space-y-6 text-[1.05rem] leading-relaxed"
        >
          <p>
            Before you reach out, it helps to be clear on what the session is
            for. What's your goal for it, who's in the audience, and what do you
            want them to be able to say or do afterwards? None of this is me
            being difficult: it's how I make sure the talk actually fits your
            audience and earns its slot.
          </p>
          <p>
            To make this easy for you, I've created an online form you can fill
            out to give me all the needed information. Please fill out the form
            at least 3 months before your event.
          </p>
        </div>
        <div class="mt-8">
          <a
            href="/contact/"
            class="bg-primary-600 hover:bg-primary-700 dark:bg-primary-500 dark:hover:bg-primary-400 font-display inline-flex items-center gap-1.5 rounded-full px-6 py-3 text-sm font-bold text-white transition"
          >
            Contact Information Form <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ============ TALK FORMAT ============ -->
    <section id="talk-format" class="relative z-10 py-[clamp(3rem,7vw,5.5rem)]">
      <div class="mx-auto max-w-3xl">
        <div class="sec-head justify-center text-center">
          <div>
            <span class="hand-note">on stage</span>
            <h2 class="leading-[1.1]">Talk format</h2>
          </div>
        </div>
        <div
          class="prose dark:prose-invert text-base-600 dark:text-base-400 mx-auto max-w-none space-y-6 text-[1.05rem] leading-relaxed"
        >
          <p>
            My talks are clear, practical sessions on usability, persuasion,
            conversion optimization, building experimentation culture, CRO teams
            and community building. I design them for a wide range of audiences
            and can adapt them for beginners or more experienced crowds. You
            walk away with things you can actually use.
          </p>
          <p>
            I usually prefer to present the opening or closing keynote at
            events, as it allows for more inspiration and practical insights.
            I'm experienced with live interviews or panels on-stage and will
            often engage with the audience for light content but will have
            conversations for the rest of the keynote. I'm also happy to
            organize the line-up where the technology-focused talks and insights
            follow, and I will focus on the background of your audience.
          </p>
          <p>
            Depending on the topic and the conference, I like to slot panels in
            between the more technical talks. My talk usually lasts 30-60
            minutes and suits an audience between 25-2500 people.
          </p>
        </div>
      </div>
    </section>

    <!-- ============ FEE ============ -->
    <section id="fee" class="relative z-10 py-[clamp(3rem,7vw,5.5rem)]">
      <div class="mx-auto max-w-3xl">
        <div class="sec-head justify-center text-center">
          <div>
            <span class="hand-note">the investment</span>
            <h2 class="leading-[1.1]">Fee</h2>
          </div>
        </div>

        <div
          class="border-base-200 dark:border-base-800 from-gold/15 rounded-3xl border bg-gradient-to-br to-transparent p-[clamp(1.5rem,4vw,3rem)]"
        >
          <div class="mb-8 text-center">
            <div
              class="font-display text-primary-600 dark:text-primary-400 mb-2 text-[clamp(2.4rem,5vw,3.2rem)] leading-none font-black tabular-nums"
            >
              €5000
            </div>
            <div class="text-base-600 dark:text-base-400 text-lg">
              + VAT + expenses (Travel + accommodation)
            </div>
          </div>

          <div
            class="prose dark:prose-invert text-base-700 dark:text-base-300 max-w-none space-y-6 text-[1.05rem] leading-relaxed"
          >
            <p>
              My talks are about entertaining and teaching an audience. I don't
              sell products or services from the stage. For commercial
              conferences I do charge a fee, since this is part of how I make a
              living. Thanks for understanding.
            </p>
            <p>
              The fee covers preparing and delivering a talk tailored to your
              audience, on topics like CRO, experimentation culture, and
              community building. The sessions work for a wide range of
              audiences, and the focus is always on practical takeaways your
              audience can use after the event.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ PAYMENT TERMS ============ -->
    <section
      id="payment-terms"
      class="relative z-10 py-[clamp(3rem,7vw,5.5rem)]"
    >
      <div class="mx-auto max-w-4xl">
        <div class="sec-head justify-center text-center">
          <div>
            <span class="hand-note">the fine print</span>
            <h2 class="leading-[1.1]">Payment terms</h2>
          </div>
        </div>

        <div class="space-y-8">
          <div
            class="prose dark:prose-invert text-base-600 dark:text-base-400 max-w-none space-y-6 text-[1.05rem] leading-relaxed"
          >
            <p>
              The fee is paid in EUR (€) via wire transfer or PayPal. I pay my
              own taxes in the Netherlands, so the quoted fee is the net amount
              I need to receive.
            </p>
            <p>
              Payment is split: a deposit to confirm the booking, ideally 3+
              months before the session, and the balance after the talk. Let me
              know which payment method works best for you.
            </p>
          </div>

          <div class="grid gap-6 md:grid-cols-2">
            <div class={card}>
              <h3 class="font-display mb-3 text-[1.1rem] font-bold">Deposit</h3>
              <p class="text-base-600 dark:text-base-400 leading-relaxed">
                50% of the quoted fee, paid to confirm and reserve your date.
              </p>
            </div>
            <div class={card}>
              <h3 class="font-display mb-3 text-[1.1rem] font-bold">
                Final Payment
              </h3>
              <p class="text-base-600 dark:text-base-400 leading-relaxed">
                The remaining balance due after your session is completed.
              </p>
            </div>
          </div>

          <div class={card}>
            <h3 class="font-display mb-4 text-[1.1rem] font-bold">
              Booking Terms
            </h3>
            <ul
              class="text-base-600 dark:text-base-400 space-y-2 leading-relaxed"
            >
              <li>
                • Once the deposit is received, your date is confirmed and
                reserved for your event.
              </li>
              <li>
                • The deposit is non-refundable once the booking is confirmed,
                as it holds the date and covers preparation.
              </li>
              <li>
                • The fee structure is <strong>fixed</strong>. If your budget is
                tight, talk to me early rather than at the end: there's more
                room to find something that works when we start the conversation
                sooner.
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ TESTIMONIALS ============ -->
    <section
      id="testimonials"
      class="relative z-10 py-[clamp(3rem,7vw,5.5rem)]"
    >
      <div class="mb-10 text-center">
        <div class="sec-head justify-center text-center">
          <div>
            <span class="hand-note">kind words</span>
            <h2 class="leading-[1.1]">What others say</h2>
          </div>
        </div>
        <p class="text-base-600 dark:text-base-400 mt-3 text-lg">
          Feedback from event organizers and attendees
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {
          testimonials.map((t) => (
            <div class={card}>
              <div class="flex items-start gap-4">
                <div class="shrink-0">
                  <div class="bg-primary-600/10 dark:bg-primary-400/15 text-primary-600 dark:text-primary-400 font-display flex size-12 items-center justify-center rounded-full font-bold">
                    {t.initial}
                  </div>
                </div>
                <div>
                  <blockquote class="text-base-700 dark:text-base-300 mb-4 leading-relaxed">
                    {t.quote}
                  </blockquote>
                  <div>
                    <div class="font-display font-bold">{t.name}</div>
                    <div class="text-base-500 text-sm">{t.role}</div>
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- ============ FEATURED PRESENTATIONS ============ -->
    <section
      id="presentations"
      class="relative z-10 py-[clamp(3rem,7vw,5.5rem)]"
    >
      <div class="mb-10 text-center">
        <div class="sec-head justify-center text-center">
          <div>
            <span class="hand-note">most requested</span>
            <h2 class="leading-[1.1]">Featured presentations</h2>
          </div>
        </div>
        <p class="text-base-600 dark:text-base-400 mt-3 text-lg">
          Some of my most popular talks that conference organizers frequently
          request
        </p>
      </div>

      <div class="mb-10 grid gap-6 md:grid-cols-3">
        {
          presentations.map((p) => (
            <a
              href={p.href}
              class="bg-base-50 dark:bg-base-900 border-base-200 dark:border-base-800 hover:border-primary-600/40 dark:hover:border-primary-400/40 group reveal block overflow-hidden rounded-2xl border text-inherit no-underline transition hover:-translate-y-0.5 hover:shadow-lg"
            >
              <div class="aspect-video overflow-hidden">
                <img
                  src={p.img}
                  alt={p.title}
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-6">
                <h3 class="font-display mb-2 text-[1.05rem] font-bold">
                  {p.title}
                </h3>
                <p class="text-base-600 dark:text-base-400 mb-4 text-sm leading-relaxed">
                  {p.desc}
                </p>
                <div class="flex items-center justify-between">
                  <span class="text-base-500 text-xs">{p.duration}</span>
                  <span class="text-primary-600 dark:text-primary-400 font-display inline-flex items-center gap-1.5 text-sm font-bold">
                    Learn more <span aria-hidden="true">→</span>
                  </span>
                </div>
              </div>
            </a>
          ))
        }
      </div>

      <div class="text-center">
        <a
          href="/presentations/"
          class="border-base-300 hover:border-primary-600 dark:border-base-500 dark:hover:border-primary-400 bg-base-100 text-base-800 dark:bg-base-700 dark:text-base-100 font-display inline-flex items-center gap-2 rounded-full border px-6 py-3 text-sm font-bold transition"
        >
          View All Presentations
        </a>
      </div>
    </section>

    <!-- ============ TRAVEL & ACCOMMODATION ============ -->
    <section id="travel" class="relative z-10 py-[clamp(3rem,7vw,5.5rem)]">
      <div class="mx-auto max-w-4xl">
        <div class="sec-head justify-center text-center">
          <div>
            <span class="hand-note">the logistics</span>
            <h2 class="leading-[1.1]">Travel &amp; accommodation</h2>
          </div>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          <div class={card}>
            <div class="text-primary-600 dark:text-primary-400 mb-3">
              <Icon
                name="tabler/outline/plane"
                class="size-6"
                aria-hidden="true"
              />
            </div>
            <h3 class="font-display mb-4 text-[1.1rem] font-bold">
              Travel Requirements
            </h3>
            <ul
              class="text-base-600 dark:text-base-400 space-y-2 leading-relaxed"
            >
              <li>• Flight booking and costs covered by organizer</li>
              <li>• Business class for flights over 3 hours</li>
              <li>• Airport transfers or rental car if needed</li>
              <li>• Travel insurance coverage</li>
            </ul>
          </div>
          <div class={card}>
            <div class="text-primary-600 dark:text-primary-400 mb-3">
              <Icon
                name="tabler/outline/luggage"
                class="size-6"
                aria-hidden="true"
              />
            </div>
            <h3 class="font-display mb-4 text-[1.1rem] font-bold">
              Accommodation
            </h3>
            <ul
              class="text-base-600 dark:text-base-400 space-y-2 leading-relaxed"
            >
              <li>• 4-star hotel or equivalent accommodation</li>
              <li>• Arrival day before event + departure day after</li>
              <li>• Quiet room for preparation (if needed)</li>
              <li>• High-speed internet access</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ AV/TECH REQUIREMENTS ============ -->
    <section id="av-tech" class="relative z-10 py-[clamp(3rem,7vw,5.5rem)]">
      <div class="mx-auto max-w-4xl">
        <div class="sec-head justify-center text-center">
          <div>
            <span class="hand-note">the setup</span>
            <h2 class="leading-[1.1]">AV/tech requirements</h2>
          </div>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          <div class={card}>
            <div class="text-primary-600 dark:text-primary-400 mb-3">
              <Icon
                name="tabler/outline/tools"
                class="size-6"
                aria-hidden="true"
              />
            </div>
            <h3 class="font-display mb-4 text-[1.1rem] font-bold">
              Basic Setup
            </h3>
            <ul
              class="text-base-600 dark:text-base-400 space-y-2 leading-relaxed"
            >
              <li>• Projector/large screen for presentations</li>
              <li>• Wireless presentation remote (clicker)</li>
              <li>• Lapel microphone (wireless preferred)</li>
              <li>• Basic lighting (standard conference setup)</li>
            </ul>
          </div>
          <div class={card}>
            <div class="text-primary-600 dark:text-primary-400 mb-3">
              <Icon
                name="tabler/outline/plug-connected"
                class="size-6"
                aria-hidden="true"
              />
            </div>
