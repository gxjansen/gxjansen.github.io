---
// layout
import BaseLayout from "@layouts/BaseLayout.astro";

// components
import { Image } from "astro:assets";
import Badge from "@components/Badge/Badge.astro";
import Button from "@components/Button/Button.astro";

// images
import speakerImage from "@images/headshot/08.02.2022_Spryker_CEO_0278.jpg";
import headshot1 from "@images/headshot/08.02.2022_Spryker_CEO_0278.jpg";
import headshot2 from "@images/headshot/08.02.2022_Spryker_CEO_2636.jpg";
import headshot3 from "@images/headshot/08.02.2022_Spryker_CEO_2669.jpg";
---

<BaseLayout
  title="Conference Terms - Guido Jansen"
  description="Everything organizers typically want to know about me. Speaking terms, requirements, and booking information."
  noindex={true}
>
  <!-- Hero Section (mt-14 matches fixed nav height h-14) -->
  <section class="relative mt-14 overflow-hidden py-24 md:py-32">
    <!-- Background with speaking photo -->
    <div class="absolute inset-0 z-0">
      <div
        class="from-primary-500/90 via-primary-500/70 to-accent-2/80 absolute inset-0 bg-gradient-to-br"
      >
      </div>
      <div class="absolute inset-0 bg-black/30"></div>
    </div>

    <div class="site-container relative z-10">
      <div class="mx-auto max-w-4xl text-center text-white">
        <Badge class="mb-6">Speaker Information</Badge>
        <h1 class="h1 mb-6 text-white">Conference Terms</h1>
        <p class="mb-8 text-xl opacity-90 md:text-2xl">
          Everything organizers typically want to know about me
        </p>
        <p class="mx-auto max-w-2xl text-lg opacity-80">
          Community Builder with 20+ years creating technical ecosystems. 200+
          conference talks across 26 countries. If you're interested in having
          me speak at your event, you'll find all the information you need
          below.
        </p>
      </div>
    </div>
  </section>

  <!-- What You Can Find Section -->
  <section class="py-16 md:py-20">
    <div class="site-container">
      <div class="mx-auto mb-16 text-center md:max-w-3xl">
        <h2 class="h2 mb-4">What you can find on this page:</h2>
      </div>

      <div class="grid grid-cols-2 gap-6 md:grid-cols-4 md:gap-8">
        <div class="group text-center">
          <div
            class="bg-base-200 group-hover:bg-primary-500/20 dark:bg-base-700/50 dark:group-hover:bg-primary-500/30 mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl transition-colors"
          >
            <svg
              class="text-primary-600 dark:text-primary-400/90 h-8 w-8"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base-900 dark:text-base-100 mb-2 font-semibold">
            Rider Kit
          </h3>
          <p class="text-base-500 dark:text-base-400 text-sm">
            Technical and logistical requirements
          </p>
        </div>

        <div class="group text-center">
          <div
            class="bg-base-200 group-hover:bg-primary-500/20 dark:bg-base-700/50 dark:group-hover:bg-primary-500/30 mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl transition-colors"
          >
            <svg
              class="text-primary-600 dark:text-primary-400/90 h-8 w-8"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base-900 dark:text-base-100 mb-2 font-semibold">
            Bio Format
          </h3>
          <p class="text-base-500 dark:text-base-400 text-sm">
            Speaker biography and credentials
          </p>
        </div>

        <div class="group text-center">
          <div
            class="bg-base-200 group-hover:bg-primary-500/20 dark:bg-base-700/50 dark:group-hover:bg-primary-500/30 mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl transition-colors"
          >
            <svg
              class="text-primary-600 dark:text-primary-400/90 h-8 w-8"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"
              ></path>
            </svg>
          </div>
          <h3 class="text-base-900 dark:text-base-100 mb-2 font-semibold">
            Fee
          </h3>
          <p class="text-base-500 dark:text-base-400 text-sm">
            Speaking fees and expenses
          </p>
        </div>

        <div class="group text-center">
          <div
            class="bg-base-200 group-hover:bg-primary-500/20 dark:bg-base-700/50 dark:group-hover:bg-primary-500/30 mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl transition-colors"
          >
            <svg
              class="text-primary-600 dark:text-primary-400/90 h-8 w-8"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base-900 dark:text-base-100 mb-2 font-semibold">
            Testimonials
          </h3>
          <p class="text-base-500 dark:text-base-400 text-sm">
            What others say about my talks
          </p>
        </div>

        <div class="group text-center">
          <div
            class="bg-base-200 group-hover:bg-primary-500/20 dark:bg-base-700/50 dark:group-hover:bg-primary-500/30 mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl transition-colors"
          >
            <svg
              class="text-primary-600 dark:text-primary-400/90 h-8 w-8"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-base-900 dark:text-base-100 mb-2 font-semibold">
            Travel & Accommodation
          </h3>
          <p class="text-base-500 dark:text-base-400 text-sm">
            Logistics and requirements
          </p>
        </div>

        <div class="group text-center">
          <div
            class="bg-base-200 group-hover:bg-primary-500/20 dark:bg-base-700/50 dark:group-hover:bg-primary-500/30 mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl transition-colors"
          >
            <svg
              class="text-primary-600 dark:text-primary-400/90 h-8 w-8"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base-900 dark:text-base-100 mb-2 font-semibold">
            AV/Tech Requirements
          </h3>
          <p class="text-base-500 dark:text-base-400 text-sm">
            Technical setup needed
          </p>
        </div>

        <div class="group text-center">
          <div
            class="bg-base-200 group-hover:bg-primary-500/20 dark:bg-base-700/50 dark:group-hover:bg-primary-500/30 mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl transition-colors"
          >
            <svg
              class="text-primary-600 dark:text-primary-400/90 h-8 w-8"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base-900 dark:text-base-100 mb-2 font-semibold">
            Content for Your Marketing
          </h3>
          <p class="text-base-500 dark:text-base-400 text-sm">
            Materials to promote the event
          </p>
        </div>

        <div class="group text-center">
          <div
            class="bg-base-200 group-hover:bg-primary-500/20 dark:bg-base-700/50 dark:group-hover:bg-primary-500/30 mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl transition-colors"
          >
            <svg
              class="text-primary-600 dark:text-primary-400/90 h-8 w-8"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base-900 dark:text-base-100 mb-2 font-semibold">
            And the Rest...
          </h3>
          <p class="text-base-500 dark:text-base-400 text-sm">
            Additional information and details
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Bio Section -->
  <section class="bg-base-200/30 dark:bg-base-700/30 py-16 md:py-20">
    <div class="site-container">
      <div class="mx-auto max-w-6xl">
        <div class="grid items-center gap-12 md:grid-cols-2">
          <div>
            <Image
              src={speakerImage}
              alt="Guido Jansen speaking at a conference"
              class="w-full rounded-2xl shadow-lg"
              widths={[400, 800, 1200]}
              sizes="(min-width: 768px) 50vw, 100vw"
              quality={90}
              format="webp"
            />
          </div>
          <div>
            <Badge class="mb-4">About the Speaker</Badge>
            <h2 class="h2 mb-6">Guido Jansen</h2>
            <div
              class="prose prose-lg text-base-500 dark:text-base-400 space-y-4"
            >
              <p>
                Guido is a Community Builder who turns technical ecosystems into
                real business growth. With 20+ years at the intersection of
                psychology and technology, he has built community functions from
                zero multiple times.
              </p>
              <p>
                His cognitive psychology background shapes how he approaches
                community work. Not by predicting how developers will behave,
                but by testing assumptions and watching what they actually do,
                because the one thing psychology reliably teaches is that you
                can't reliably predict people.
              </p>
              <p>
                He has presented at 200+ conferences across 26 countries on
                topics including composable commerce, community building, and
                digital psychology.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Am I the Right Fit Section -->
  <section class="py-16 md:py-20">
    <div class="site-container">
      <div class="mx-auto mb-12 max-w-4xl text-center">
        <div
          class="bg-primary-500/10 mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl"
        >
          <svg
            class="text-primary-600 dark:text-primary-400 h-8 w-8"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <h2 class="h2 mb-6">Am I the right fit?</h2>
      </div>

      <div class="mx-auto max-w-3xl">
        <div
          class="prose prose-lg text-base-500 dark:text-base-400 mx-auto space-y-6 text-center"
        >
          <p>
            Before you reach out, it helps to be clear on what the session is
            for. What's your goal for it, who's in the audience, and what do you
            want them to be able to say or do afterwards? None of this is me
            being difficult: it's how I make sure the talk actually fits your
            audience and earns its slot.
          </p>
          <p>
            To make this easy for you, I've created an online form you can fill
            out to give me all the needed information. Please fill out the form
            at least 3 months before your event.
          </p>
          <div class="mt-8">
            <Button href="/contact/" variant="primary">
              Contact Information Form
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Talk Format Section -->
  <section class="bg-base-200/30 dark:bg-base-700/30 py-16 md:py-20">
    <div class="site-container">
      <div class="mx-auto mb-12 max-w-4xl text-center">
        <div
          class="bg-primary-500/10 mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl"
        >
          <svg
            class="text-primary-600 dark:text-primary-400 h-8 w-8"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M7 4V2a1 1 0 011-1h8a1 1 0 011 1v2m0 0V3a1 1 0 011 1v1M7 4V3a1 1 0 011-1m0 0h8m-8 0V2m8 2v1m0-1V2m0 2h1M8 7h8v10H8V7z"
            ></path>
          </svg>
        </div>
        <h2 class="h2 mb-6">Talk format</h2>
      </div>

      <div class="mx-auto max-w-3xl">
        <div
          class="prose prose-lg text-base-500 dark:text-base-400 mx-auto space-y-6"
        >
          <p>
            My talks are easy to understand sessions on usability, persuasion,
            conversion optimization, building experimentation culture, CRO teams
            and community building. They are usually designed for a wide variety
            of audiences and can be adapted to fit beginners as well as
            intermediate audiences. The focus is on building audience awareness
            while providing actionable takeaways.
          </p>
          <p>
            I usually prefer to present the opening or closing keynote at
            events, as it allows for more inspiration and practical insights.
            I'm experienced with live interviews or panels on-stage and will
            often engage with the audience for light content but will have
            conversations for the rest of the keynote. I'm also happy to
            organize the line-up where the technology-focused talks and insights
            follow, and I will focus on the background of your audience.
          </p>
          <p>
            Depending on the topic and the conference, I usually prefer to
            present the opening or closing keynote at events, with panels
            in-between technical talks. My talk usually lasts 30-60 minutes and
            suits an audience between 25-2500 people.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Fee Section -->
  <section class="py-16 md:py-20">
    <div class="site-container">
      <div class="mx-auto mb-12 max-w-4xl text-center">
        <div
          class="bg-primary-500/10 mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl"
        >
          <svg
            class="text-primary-600 dark:text-primary-400 h-8 w-8"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"
            ></path>
          </svg>
        </div>
        <h2 class="h2 mb-6">Fee</h2>
      </div>

      <div class="mx-auto max-w-4xl">
        <div
          class="border-base-200 bg-base-100 dark:border-base-700 dark:bg-base-900 rounded-2xl border p-8 shadow-xs"
        >
          <div class="mb-8 text-center">
            <div
              class="text-primary-600 dark:text-primary-400 mb-2 text-4xl font-bold"
            >
              €5000
            </div>
            <div class="text-base-500 dark:text-base-400 text-lg">
              + VAT + expenses (Travel + accommodation)
            </div>
          </div>

          <div
            class="prose prose-lg text-base-500 dark:text-base-400 space-y-6"
          >
            <p>
              My talks are about entertaining and teaching an audience. I don't
              sell products or services from the stage. For commercial
              conferences I do charge a fee, since this is part of how I make a
              living. Thanks for understanding.
            </p>
            <p>
              The fee covers preparing and delivering a talk tailored to your
              audience, on topics like CRO, experimentation culture, and
              community building. The sessions work for a wide range of
              audiences, and the focus is always on practical takeaways your
              audience can use after the event.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Payment Terms Section -->
  <section class="bg-base-200/30 dark:bg-base-700/30 py-16 md:py-20">
    <div class="site-container">
      <div class="mx-auto mb-12 max-w-4xl text-center">
        <h2 class="h2 mb-6">Payment terms</h2>
      </div>

      <div class="mx-auto max-w-6xl">
        <div class="space-y-8">
          <div
            class="prose prose-lg text-base-500 dark:text-base-400 max-w-none space-y-6"
          >
            <p>
              The fee is paid in EUR (€) via wire transfer or PayPal. I pay my
              own taxes in the Netherlands, so the quoted fee is the net amount
              I need to receive.
            </p>
            <p>
              Payment is split: a deposit to confirm the booking, ideally 3+
              months before the session, and the balance after the talk. Let me
              know which payment method works best for you.
            </p>
          </div>

          <div class="grid gap-8 md:grid-cols-2">
            <div
              class="border-base-200 bg-base-100 dark:border-base-700 dark:bg-base-900 rounded-xl border p-6"
            >
              <h3
                class="text-base-900 dark:text-base-100 mb-4 text-xl font-semibold"
              >
                Deposit
              </h3>
              <p class="text-base-500 dark:text-base-400">
                50% of the quoted fee, paid to confirm and reserve your date.
              </p>
            </div>
            <div
              class="border-base-200 bg-base-100 dark:border-base-700 dark:bg-base-900 rounded-xl border p-6"
            >
              <h3
                class="text-base-900 dark:text-base-100 mb-4 text-xl font-semibold"
              >
                Final Payment
              </h3>
              <p class="text-base-500 dark:text-base-400">
                The remaining balance due after your session is completed.
              </p>
            </div>
          </div>

          <div
            class="border-base-200 bg-base-100 dark:border-base-700 dark:bg-base-900 rounded-xl border p-6"
          >
            <h3
              class="text-base-900 dark:text-base-100 mb-4 text-xl font-semibold"
            >
              Booking Terms
            </h3>
            <ul class="text-base-500 dark:text-base-400 space-y-2">
              <li>
                • Once the deposit is received, your date is confirmed and
                reserved for your event.
              </li>
              <li>
                • The deposit is non-refundable once the booking is confirmed,
                as it holds the date and covers preparation.
              </li>
              <li>
                • The fee structure is <strong>fixed</strong>. If your budget is
                tight, talk to me early rather than at the end: there's more
                room to find something that works when we start the conversation
                sooner.
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-16 md:py-20">
    <div class="site-container">
      <div class="mx-auto mb-12 max-w-4xl text-center">
        <div
          class="bg-primary-500/10 mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl"
        >
          <svg
            class="text-primary-600 dark:text-primary-400 h-8 w-8"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"
            ></path>
          </svg>
        </div>
        <h2 class="h2 mb-6">What others say</h2>
        <p class="text-base-500 dark:text-base-400 text-lg">
          Feedback from event organizers and attendees
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <div
          class="border-base-200 bg-base-100 dark:border-base-700 dark:bg-base-900 rounded-xl border p-6"
        >
          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0">
              <div
                class="bg-base-200 dark:bg-base-700/50 flex h-12 w-12 items-center justify-center rounded-full"
              >
                <span
                  class="text-primary-600 dark:text-primary-400 font-semibold"
                  >E</span
                >
              </div>
            </div>
            <div>
              <blockquote class="text-base-500 dark:text-base-400 mb-4">
                "Guido is an excellent public speaker. Whether it's a workshop,
                a conference talk, or a meetup, he always manages to bring
                energy and knowledge to his presentations."
              </blockquote>
              <div>
                <div class="text-base-900 dark:text-base-100 font-semibold">
                  Erin Weigel
                </div>
                <div class="text-base-500 dark:text-base-400 text-sm">
                  Advisor, ABsmartly
                </div>
              </div>
            </div>
          </div>
        </div>

        <div
          class="border-base-200 bg-base-100 dark:border-base-700 dark:bg-base-900 rounded-xl border p-6"
        >
          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0">
              <div
                class="bg-base-200 dark:bg-base-700/50 flex h-12 w-12 items-center justify-center rounded-full"
              >
                <span
                  class="text-primary-600 dark:text-primary-400 font-semibold"
                  >A</span
                >
              </div>
            </div>
            <div>
              <blockquote class="text-base-500 dark:text-base-400 mb-4">
                "Give him a stage and the audience will love him!"
