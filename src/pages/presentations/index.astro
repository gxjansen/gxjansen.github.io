---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import PresentationCard from "@components/Presentations/PresentationCard.astro";
import { getCollection } from "astro:content";

const all: CollectionEntry<"presentations">[] =
  await getCollection("presentations");

const valid = all.filter(
  (p) => p.data.title && p.data.image && p.data.isHidden !== true,
);
const byTitle = (a: CollectionEntry<"presentations">, b: typeof a) =>
  (a.data.title ?? "").localeCompare(b.data.title ?? "");

const featured = valid.filter((p) => p.data.isFeatured).sort(byTitle);
const other = valid.filter((p) => !p.data.isFeatured).sort(byTitle);

const grid = "grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3";
---

<BaseLayout
  title="Presentations"
  description="Presentations and workshops by Guido Jansen on community building, developer ecosystems, experimentation and the psychology of customer behavior."
  type="presentationList"
  presentations={valid.map((p) => p.data)}
  presentationSlugs={valid.map((p) => p.id)}
>
  <div class="home presentations-page">
    <section
      class="relative z-10 pt-[clamp(4.5rem,9vw,7rem)] pb-[clamp(2rem,5vw,4rem)]"
    >
      <span class="eyebrow">Speaking</span>
      <h1
        class="font-display mt-2 mb-4 text-[clamp(2.2rem,5vw,3.2rem)] leading-[1.05] font-black tracking-[-0.03em]"
      >
        Presentations &amp; workshops
      </h1>
      <p
        class="text-base-600 dark:text-base-400 max-w-[60ch] text-lg leading-relaxed"
      >
        A selection of my most-requested talks and workshops. <a
          href="/contact/"
          class="text-primary-600 dark:text-primary-400 font-semibold"
          >Get in touch</a
        > if you'd like me to speak at your event.
      </p>
    </section>

    <section class="relative z-10 pb-[clamp(3rem,7vw,5.5rem)]">
      <div class="sec-head">
        <div>
          <span class="hand-note">most requested</span>
          <h2>Featured</h2>
        </div>
      </div>
      <div class={grid}>
        {featured.map((p) => <PresentationCard presentation={p} />)}
      </div>
    </section>

    {
      other.length > 0 && (
        <section class="relative z-10 pb-[clamp(3rem,7vw,5.5rem)]">
          <div class="sec-head">
            <div>
              <span class="hand-note">more sessions</span>
              <h2>The full catalogue</h2>
            </div>
          </div>
          <div class={grid}>
            {other.map((p) => (
              <PresentationCard presentation={p} />
            ))}
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>
