---
// layout
import BaseLayout from "@layouts/BaseLayout.astro";

// components
import SlideEmbed from "@components/Presentations/SlideEmbed.astro";
import VideoEmbed from "@components/Presentations/VideoEmbed.astro";
import PresentationNav from "@components/Presentations/PresentationNav.astro";
import RelatedEvents from "@components/RelatedEvents/RelatedEvents.astro";

// content
import { getCollection, render } from "astro:content";

// Generate static paths for all non-hidden presentations
export async function getStaticPaths() {
  const allPresentations = await getCollection("presentations");
  // Filter out presentations with isHidden: true
  const visiblePresentations = allPresentations.filter(
    (p) => p.data.isHidden !== true,
  );

  return visiblePresentations.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, presentations: visiblePresentations },
  }));
}

const { entry, presentations } = Astro.props;
const { Content } = await render(entry);
const {
  title,
  duration,
  intendedAudience,
  isWorkshop,
  image,
  slideshareKey,
  youtubeId,
} = entry.data;

const metaDescription = `${title}${intendedAudience ? ` - For ${intendedAudience}` : ""}. ${duration} presentation${isWorkshop ? " workshop" : ""}.`;
const metaImage = image ? new URL(image, Astro.site) : undefined;
---

<BaseLayout
  title={`${title} | Presentations`}
  description={metaDescription}
  image={metaImage as any}
  type="presentation"
  presentation={entry.data}
  presentationSlug={entry.id}
>
  <div slot="head">
    <link rel="preload" as="image" href={image} />
    {youtubeId && <link rel="preconnect" href="https://www.youtube.com" />}
    {
      slideshareKey && (
        <link rel="preconnect" href="https://www.slideshare.net" />
      )
    }
  </div>

  <div class="home presentation-page">
    <section
      class="relative z-10 pt-[clamp(4.5rem,9vw,7rem)] pb-[clamp(3rem,7vw,5.5rem)]"
    >
      <div class="mx-auto max-w-3xl">
        <a
          href="/presentations/"
          class="text-base-500 hover:text-primary-600 dark:hover:text-primary-400 mb-6 inline-flex items-center gap-1.5 text-sm font-semibold transition"
        >
          <span aria-hidden="true">←</span> All presentations
        </a>

        <span class="eyebrow">{isWorkshop ? "Workshop" : "Presentation"}</span>
        <h1
          class="font-display mt-2 mb-4 text-[clamp(1.9rem,4vw,2.7rem)] leading-tight font-black tracking-[-0.03em]"
        >
          {title}
        </h1>

        <div class="mb-5 flex flex-wrap gap-2">
          {duration && <span class="chip chip--plain">{duration}</span>}
          {isWorkshop && <span class="chip">Workshop</span>}
        </div>

        {
          intendedAudience && (
            <p class="text-base-600 dark:text-base-400 text-lg">
              <span class="font-semibold">For:</span> {intendedAudience}
            </p>
          )
        }

        <div class="prose prose-lg dark:prose-invert mt-8 max-w-none">
          <div class="not-prose mb-8 overflow-hidden rounded-2xl">
            <img
              src={image}
              alt={title}
              width="800"
              height="450"
              class="aspect-video w-full object-cover"
              loading="eager"
            />
          </div>

          <Content />
        </div>

        {
          slideshareKey && (
            <div class="mt-10">
              <SlideEmbed slideshareKey={slideshareKey} />
            </div>
          )
        }
        {
          youtubeId && (
            <div class="mt-10">
              <VideoEmbed youtubeId={youtubeId} />
            </div>
          )
        }

        <div class="mt-12">
          <PresentationNav
            currentSlug={entry.id}
            presentations={presentations}
          />
        </div>

        <RelatedEvents presentationSlug={entry.id} />
      </div>
    </section>
  </div>
</BaseLayout>
