---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { format } from "date-fns";

// components
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumb from "@components/Breadcrumb/Breadcrumb.astro";

// utils
import { countItems, sortByValue } from "@js/blogUtils";
import { slugify } from "@js/textUtils";
import { readingTimeShort } from "../../utils/readingTime";

export async function getStaticPaths() {
  // Get all posts
  const posts = await getCollection("post", ({ data }) => {
    return !data.draft;
  });

  // Get all categories and their original names
  const allCategories = posts
    .map((post) => post.data.categories || [])
    .flat()
    .filter(Boolean);

  const uniqueCategories = [...new Set(allCategories)];

  // Create a path for each category, storing both slugified and original versions
  // Count posts per category
  const categoryCount = countItems(allCategories);
  const validCategories = uniqueCategories.filter(
    (category) => categoryCount[slugify(category)]?.count >= 2,
  );

  return validCategories.map((category) => ({
    params: { category: slugify(category) },
    props: {
      slugifiedCategory: slugify(category),
      originalCategory: category,
    },
  }));
}

// Get both versions of the category from props
const { slugifiedCategory, originalCategory } = Astro.props;

// Get all posts
const posts = await getCollection("post", ({ data }) => {
  return !data.draft;
});

// Filter posts by category, ensuring categories exist
const filteredPosts = posts
  .filter((post) =>
    (post.data.categories || [])
      .map((cat) => slugify(cat))
      .includes(slugifiedCategory),
  )
  .sort(
    (a, b) =>
      new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
  );

const accents = ["gold", "foam", "pine", "iris", "love", "rose"] as const;

const articles = filteredPosts.map((post, i) => ({
  title: post.data.title,
  description: post.data.description,
  href: `/post/${post.id}/`,
  date: format(new Date(post.data.pubDate), "MMM d, yyyy"),
  read: readingTimeShort(post.body),
  categories: post.data.categories || [],
  heroImage: post.data.heroImage,
  accent: accents[i % accents.length],
}));

// Get all categories for the filter bar, keeping those with 2+ posts.
const categories = posts
  .map((post) => post.data.categories || [])
  .flat()
  .filter(Boolean);
const processedCategories = sortByValue(countItems(categories)).filter(
  ([_, __, count]) => count >= 2,
);

// Set up page metadata
const title = `Posts in category: ${originalCategory}`;
const description = `Articles categorized under ${originalCategory}`;
---

<BaseLayout title={title} description={description}>
  <div class="home">
    <section
      class="relative z-10 pt-[clamp(4.5rem,9vw,7rem)] pb-[clamp(2rem,5vw,4rem)]"
    >
      <Breadcrumb
        class="mb-8"
        items={[
          { label: "Home", href: "/" },
          { label: "Categories", href: "/post/" },
          { label: originalCategory },
        ]}
      />

      <div class="mb-10 max-w-3xl">
        <span class="eyebrow mb-3">Category</span>
        <h1
          class="font-display mt-2 text-[clamp(2.4rem,5vw,3.6rem)] leading-[1.05] font-black tracking-[-0.03em]"
        >
          {originalCategory}
        </h1>
        <p
          class="text-base-600 dark:text-base-400 mt-4 text-lg leading-relaxed"
        >
          Articles related to {originalCategory.toLowerCase()}.
        </p>
      </div>

      <!-- Category filter -->
      <div
        class="mb-8 flex flex-wrap gap-2"
        role="group"
        aria-label="Browse articles by category"
      >
        <a class="fbtn" href="/post/">All articles</a>
        {
          processedCategories.map(([slug, original]) => (
            <a
              class:list={["fbtn", { active: slug === slugifiedCategory }]}
              href={`/categories/${slug}/`}
              aria-current={slug === slugifiedCategory ? "page" : undefined}
            >
              {original}
            </a>
          ))
        }
      </div>

      <!-- Article grid -->
      <div class="grid grid-cols-1 gap-[1.1rem] sm:grid-cols-2 lg:grid-cols-3">
        {
          articles.map((a) => (
            <a
              class="art reveal"
              href={a.href}
              style={`--ac:var(--color-${a.accent})`}
            >
              {a.heroImage && (
                <div class="art-thumb">
                  <Image src={a.heroImage} alt="" width={520} height={280} />
                </div>
              )}
              <div class="tags">
                {a.categories.slice(0, 2).map((t) => (
                  <span class="tg">{t}</span>
                ))}
              </div>
              <h3>{a.title}</h3>
              {a.description && <p>{a.description}</p>}
              <div class="m">
                <span>{a.date}</span>
                <span aria-hidden="true">·</span>
                <span class="read-time">{a.read}</span>
                <span class="read">
                  Read <span aria-hidden="true">↗</span>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
