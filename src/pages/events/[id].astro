---
// layout
import BaseLayout from "@layouts/BaseLayout.astro";

// components
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import RelatedPresentations from "@components/RelatedPresentations/RelatedPresentations.astro";

// utils
import { getAllEvents } from "@utils/eventUtils";
import { getPresentationUrl } from "@utils/eventPresentationRelations";
import { loadCountryFlag } from "@utils/flagUtils";
import type { Event } from "@utils/eventUtils";

// Generate static paths for all events
export async function getStaticPaths() {
  const events = await getAllEvents();
  return events.map((event) => {
    const presentationUrl = getPresentationUrl(event.id);
    return {
      params: { id: event.id },
      props: { event, presentationUrl },
    };
  });
}

// Get event data
const { event } = Astro.props as {
  event: Event;
  presentationUrl?: string;
};

// Country helpers. Names come from Intl.DisplayNames; flags are rendered as
// SVGs via the project's flag utilities (svg-country-flags) — the SAME approach
// used by the events index / EventCard — so flags stay consistent across pages.
// Both degrade gracefully (no flag / raw code) when the code is invalid.
const countryNames = new Intl.DisplayNames(["en"], { type: "region" });

function countryToName(code?: string): string | null {
  if (!code) return null;
  const cc = code.trim().toUpperCase();
  if (!/^[A-Z]{2}$/.test(cc)) return null;
  try {
    return countryNames.of(cc) ?? cc;
  } catch {
    return cc;
  }
}

// Load the country flag SVG at build time (ImageMetadata) — null if unavailable.
const flagImage = event.country ? await loadCountryFlag(event.country) : null;
const countryName = countryToName(event.country);

// Format date
const eventDate = new Date(event.date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// Enhanced SEO title with year, city, and country
const eventYear = new Date(event.date).getFullYear();
const enhancedTitle = `${event.name} ${eventYear} - ${event.city}${event.country ? `, ${event.country}` : ""} | Events`;

// Enhanced metadata description with comprehensive details
const descriptionParts = [
  `${event.name} - ${eventDate} in ${event.city}${event.country ? `, ${event.country}` : ""}.`,
  event.role ? `Role: ${event.role}.` : "",
  event.topic ? `Topic: ${event.topic}.` : "",
  event.workshop
    ? "This was a hands-on workshop event."
    : "Professional speaking engagement.",
];
const metaDescription = descriptionParts.filter(Boolean).join(" ");
---

<BaseLayout
  title={enhancedTitle}
  description={metaDescription}
  type="event"
  event={event}
>
  <div class="home events-detail-page">
    <!-- ============ HERO ============ -->
    <section
      class="relative z-10 pt-[clamp(6rem,9vw,7rem)] pb-[clamp(2rem,5vw,4rem)]"
    >
      <div class="max-w-[60ch]">
        <span class="hand-note">on the road</span>
        <h1
          class="font-display mt-1 mb-4 text-[clamp(2.2rem,5vw,3.2rem)] leading-[1.1] font-black tracking-[-0.03em]"
        >
          {event.name}
        </h1>

        <div class="mb-5 flex flex-wrap items-center gap-2">
          <span class="chip chip--plain">
            <Icon
              name="tabler/outline/calendar"
              class="size-5"
              aria-hidden="true"
            />
            {eventDate}
          </span>
          <span class="chip chip--plain">
            <Icon
              name="tabler/outline/map-pin"
              class="size-5"
              aria-hidden="true"
            />
            <span
              >{event.city}{
                event.country && `, ${countryName ?? event.country}`
              }</span
            >
            {
              flagImage && (
                <Image
                  src={flagImage}
                  alt={`Flag of ${countryName ?? event.country}`}
                  width={20}
                  height={15}
                  class="inline-block rounded-xs mix-blend-multiply dark:mix-blend-screen"
                  loading="lazy"
                />
              )
            }
          </span>
          {
            event.workshop && (
              <span class="chip">
                <Icon
                  name="tabler/outline/tools"
                  class="size-5"
                  aria-hidden="true"
                />
                Workshop
              </span>
            )
          }
        </div>
      </div>
    </section>

    <!-- ============ DETAILS ============ -->
    <section class="relative z-10 pb-[clamp(3rem,7vw,5.5rem)]">
      <div
        class="bg-base-50 dark:bg-base-900 border-base-200 dark:border-base-800 flex flex-col items-start gap-6 rounded-2xl border p-5 sm:flex-row sm:items-center"
      >
        {
          event.loadedIcon && (
            <div class="border-base-200 dark:border-base-800 flex size-20 shrink-0 items-center justify-center rounded-xl border bg-white p-2">
              <Image
                src={event.loadedIcon}
                alt={`${event.name} logo`}
                class="size-full object-contain"
                width={96}
                height={96}
                loading="lazy"
              />
            </div>
          )
        }
        <dl class="flex flex-1 flex-col gap-3">
          {
            event.role && (
              <div class="flex flex-col gap-0.5">
                <dt class="text-base-500 text-xs font-bold tracking-[0.06em] uppercase">
                  Role
                </dt>
                <dd class="text-base-700 dark:text-base-300 text-base leading-relaxed">
                  {event.role}
                </dd>
              </div>
            )
          }
          {
            event.topic && (
              <div class="flex flex-col gap-0.5">
                <dt class="text-base-500 text-xs font-bold tracking-[0.06em] uppercase">
                  Topic
                </dt>
                <dd class="text-base-700 dark:text-base-300 text-base leading-relaxed">
                  {event.topic}
                </dd>
              </div>
            )
          }
          <div class="flex flex-col gap-0.5">
            <dt
              class="text-base-500 text-xs font-bold tracking-[0.06em] uppercase"
            >
              Location
            </dt>
            <dd
              class="text-base-700 dark:text-base-300 flex items-center gap-1.5 text-base leading-relaxed"
            >
              <span
                >{event.city}{
                  event.country && `, ${countryName ?? event.country}`
                }</span
              >
              {
                flagImage && (
                  <Image
                    src={flagImage}
                    alt={`Flag of ${countryName ?? event.country}`}
                    width={20}
                    height={15}
                    class="inline-block rounded-xs mix-blend-multiply dark:mix-blend-screen"
                    loading="lazy"
                  />
                )
              }
            </dd>
          </div>
        </dl>
      </div>

      {
        event.url && (
          <a
            href={event.url}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-primary-600 hover:bg-primary-700 dark:bg-primary-500 dark:hover:bg-primary-400 font-display mt-6 inline-flex items-center gap-1.5 rounded-full px-6 py-3 text-sm font-bold text-white transition"
          >
            Visit event website <span aria-hidden="true">→</span>
          </a>
        )
      }
    </section>

    <!-- ============ RELATED PRESENTATIONS ============ -->
    <section class="relative z-10 pb-[clamp(3rem,7vw,5.5rem)]">
      <RelatedPresentations eventId={event.id} />
    </section>
  </div>
</BaseLayout>
