---
// utils
import { getCollection } from "astro:content";

// components
import BaseLayout from "@layouts/BaseLayout.astro";
import PostCardAtlas from "@components/PostCard/PostCardAtlas.astro";
import Badge from "@components/Badge/Badge.astro";

// Get all posts
const posts = await getCollection("post", ({ data }) => {
  return !data.draft;
});

// Sort by date (newest first)
const sortedPosts = posts.sort(
  (a, b) =>
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
);
---

<BaseLayout
  title="Blog | Guido X Jansen"
  description="Articles on community building, developer ecosystems, experimentation, and psychology-driven growth strategies."
>
  <section class="py-24 md:py-28">
    <div class="site-container">
      <div>
        <div class="relative">
          <div class="mx-auto mb-16 text-center md:max-w-4xl">
            <Badge>Blog</Badge>
            <h1 class="h1 mb-4">Latest Articles</h1>
            <p class="description text-lg md:text-xl">
              I write about psychology, experimentation, e-commerce, homelabbing
              and more. Below you can find my latest articles.
            </p>
          </div>

          <!-- Blog posts grid -->
          <div class="mx-auto max-w-6xl">
            <div class="cards-grid">
              {
                sortedPosts.map((post) => (
                  <PostCardAtlas post={post} showDescription={true} />
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
