---
import { Image } from "astro:assets";
import { getRelativeLocaleUrl } from "astro:i18n";

import BaseLayout from "@layouts/BaseLayout.astro";
import { getLocaleFromUrl } from "@js/localeUtils";
import errorImage from "@images/404.webp";

const currLocale = getLocaleFromUrl(Astro.url);
---

<BaseLayout title="404" description="Error 404 page not found." noindex={true}>
  <div class="home error-page">
    <section
      class="relative z-10 pt-[clamp(6rem,9vw,7rem)] pb-[clamp(3rem,7vw,5.5rem)]"
    >
      <div
        class="grid grid-cols-1 items-center gap-[clamp(1.5rem,4vw,3rem)] md:grid-cols-2"
      >
        <div class="order-2 md:order-1">
          <span class="hand-note">error 404</span>
          <h1
            class="font-display mt-2 mb-4 text-[clamp(2.2rem,5vw,3.2rem)] leading-[1.05] font-black tracking-[-0.03em]"
          >
            This page wandered off
          </h1>
          <p
            class="text-base-600 dark:text-base-400 max-w-[48ch] text-lg leading-relaxed"
          >
            The link's broken or the page moved. Let's get you back on track.
          </p>
          <a
            href={getRelativeLocaleUrl(currLocale, "/")}
            class="bg-primary-600 hover:bg-primary-700 dark:bg-primary-500 dark:hover:bg-primary-400 font-display mt-6 inline-flex items-center gap-1.5 rounded-full px-6 py-3 text-sm font-bold text-white transition"
          >
            Back to homepage <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class="order-1 md:order-2">
          <Image
            src={errorImage}
            class="mx-auto rounded-2xl"
            alt="Error 404"
            loading="eager"
            width={600}
            densities={[1.5, 2]}
          />
        </div>
      </div>
    </section>
  </div>

  <!-- Track 404 with Umami -->
  <script>
    if (typeof umami !== "undefined") {
      umami.track("404-page", {
        url: window.location.pathname,
        referrer: document.referrer || "direct",
      });
    }
  </script>
</BaseLayout>
