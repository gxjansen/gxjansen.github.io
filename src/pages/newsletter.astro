---
/**
 * Newsletter subscription page with detailed information about
 * content expectations, privacy, and GDPR compliance.
 */
import BaseLayout from "@layouts/BaseLayout.astro";
import NewsletterForm from "@components/Newsletter/NewsletterForm.astro";
import { yearsBuilding } from "@data/siteStats";
---

<BaseLayout
  title="Newsletter"
  description="Big Tech alternatives, AI meets DevRel, automation tips, and personal updates I don't share on social. No spam, no tracking."
>
  <div class="home newsletter-page">
    <section
      class="relative z-10 pt-[clamp(4.5rem,9vw,7rem)] pb-[clamp(1.5rem,4vw,2.5rem)]"
    >
      <div class="mx-auto max-w-2xl text-center">
        <span class="hand-note">the full story</span>
        <h1
          class="font-display mt-2 mb-4 text-[clamp(2.2rem,5vw,3.2rem)] leading-[1.05] font-black tracking-[-0.03em]"
        >
          The newsletter
        </h1>
        <p class="text-base-600 dark:text-base-400 text-lg leading-relaxed">
          Social media gets the highlights. The newsletter gets the full story.
        </p>
      </div>
    </section>

    <NewsletterForm
      variant="card"
      title="Get Guido's <span class='text-golden'>Golden</span> Nuggets"
      description="Occasional field notes on <strong>community, experimentation, AI & open tech</strong>. The things I'd tell a friend over coffee, not a content calendar."
    />

    <section class="relative z-10 py-[clamp(3rem,7vw,5.5rem)]">
      <div class="mx-auto max-w-2xl">
        <p class="text-base-700 dark:text-base-300 text-center text-lg">
          {yearsBuilding}+ years at the intersection of technology, community,
          and business. This newsletter shares what I've learned and what I'm
          building for the future.
        </p>

        <div class="prose dark:prose-invert mx-auto mt-10 max-w-none">
          <h2>What you get</h2>
          <p>A few times a year, scannable and focused:</p>
          <ul>
            <li>
              <strong>Big Tech alternatives:</strong> privacy-respecting tools for
              becoming more sovereign with your data
            </li>
            <li>
              <strong>AI + DevRel/Community:</strong> how AI developments intersect
              with community building and developer relations
            </li>
            <li>
              <strong>Automation recipes:</strong> n8n workflows and homelab wins
              worth sharing
            </li>
            <li>
              <strong>Personal updates:</strong> what I'm working on and learning,
              beyond what I share on social
            </li>
          </ul>
          <p>Reply to any email and it goes straight to me.</p>

          <h2>Privacy-first</h2>
          <p>
            Self-hosted on EU servers. I keep your data private and share it
            with no one.
          </p>
          <p>
            <a href="/privacy/#newsletter">Full privacy details</a> | <a
              href="/contact/">Questions?</a
            >
          </p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
