---
import { Icon } from "astro-icon/components";
import BaseLayout from "@layouts/BaseLayout.astro";
import { courses, courseBySlug } from "@data/training";

export function getStaticPaths() {
  return courses.map((c) => ({
    params: { course: c.slug },
    props: { course: c },
  }));
}

const { course } = Astro.props;
const ac = `--ac:var(--color-${course.accent})`;
---

<BaseLayout
  title={`${course.t} — Training | Guido X Jansen`}
  description={course.sub}
>
  <div class="home">
    <section
      class="relative z-10 pt-[clamp(4.5rem,9vw,7rem)] pb-[clamp(2rem,4vw,3rem)]"
      style={ac}
    >
      <a
        href="/training/"
        class="text-base-500 hover:text-primary-600 dark:hover:text-primary-400 mb-6 inline-flex items-center gap-1 text-sm font-medium"
        >← All training</a
      >
      <span class="tlevel" style={ac}>{course.level} · {course.fmt}</span>
      <h1
        class="font-display mt-3 max-w-3xl text-[clamp(2.2rem,5vw,3.4rem)] leading-[1.05] font-black tracking-[-0.03em]"
      >
        {course.t}
      </h1>
      <p
        class="text-base-600 dark:text-base-400 mt-3 max-w-2xl text-xl leading-relaxed"
      >
        {course.sub}
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="/contact/"
          class="bg-primary-600 hover:bg-primary-700 dark:bg-primary-500 dark:hover:bg-primary-400 focus:ring-primary-500 font-display inline-flex items-center rounded-full px-6 py-3 font-bold text-white transition focus:ring-2 focus:ring-offset-2 focus:outline-hidden"
          >Book this workshop</a
        >
        <a
          href="/speaker/"
          class="border-base-300 hover:border-primary-600 dark:border-base-700 dark:hover:border-primary-400 bg-base-50 dark:bg-base-800/60 text-base-900 dark:text-base-100 font-display inline-flex items-center rounded-full border px-6 py-3 font-bold transition"
          >Other formats</a
        >
      </div>
    </section>

    <!-- Who it's for -->
    <section class="relative z-10 pb-[clamp(3rem,6vw,5rem)]">
      <h2 class="font-display mb-6 text-2xl font-extrabold tracking-[-0.02em]">
        Who it's for
      </h2>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
        {
          course.forWho.map((w) => (
            <div class="surface rounded-2xl p-6">
              <div class="text-primary-600 dark:text-primary-400 bg-primary-600/10 dark:bg-primary-400/15 mb-4 flex size-11 items-center justify-center rounded-xl">
                <Icon name={w.icon} class="size-5" aria-hidden="true" />
              </div>
              <h3 class="font-display text-lg font-bold">{w.t}</h3>
              <p class="text-base-600 dark:text-base-400 mt-1 text-[0.95rem] leading-relaxed">
                {w.d}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- What you'll leave with -->
    <section class="relative z-10 pb-[clamp(3rem,6vw,5rem)]">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-[1.1fr_0.9fr]">
        <div>
          <h2
            class="font-display mb-6 text-2xl font-extrabold tracking-[-0.02em]"
          >
            What you'll leave with
          </h2>
          <ul class="flex flex-col gap-3">
            {
              course.outcomes.map((o) => (
                <li class="flex items-start gap-3">
                  <span
                    class="text-primary-600 dark:text-primary-400 mt-0.5 shrink-0"
                    aria-hidden="true"
                  >
                    <Icon name="tabler/circle-check" class="size-5" />
                  </span>
                  <span class="text-base-700 dark:text-base-300 leading-relaxed">
                    {o}
                  </span>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Agenda -->
        <div>
          <h2
            class="font-display mb-6 text-2xl font-extrabold tracking-[-0.02em]"
          >
            How the day runs
          </h2>
          <div class="flex flex-col gap-4">
            {
              course.agenda.map((a) => (
                <div class="surface rounded-2xl p-5">
                  <span class="eyebrow">{a.time}</span>
                  <h3 class="font-display mt-1 text-lg font-bold">{a.t}</h3>
                  <p class="text-base-600 dark:text-base-400 mt-1 text-[0.95rem] leading-relaxed">
                    {a.d}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Why me -->
    <section class="relative z-10 pb-[clamp(3rem,7vw,5.5rem)]">
      <div class="surface rounded-3xl p-6 sm:p-8" style={ac}>
        <span class="eyebrow">Why learn this from me</span>
        <p
          class="text-base-800 dark:text-base-200 mt-3 max-w-3xl text-lg leading-relaxed"
        >
          {course.whyMe}
        </p>
        <a
          href="/contact/"
          class="bg-primary-600 hover:bg-primary-700 dark:bg-primary-500 dark:hover:bg-primary-400 focus:ring-primary-500 font-display mt-6 inline-flex items-center rounded-full px-6 py-3 font-bold text-white transition focus:ring-2 focus:ring-offset-2 focus:outline-hidden"
          >Talk about a workshop</a
        >
      </div>
    </section>
  </div>
</BaseLayout>
