---
// main layout
import BaseLayout from "@layouts/BaseLayout.astro";

// components
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

// images for communities
import joomlaLogo from "@images/events/joomla.png";
import magentoLogo from "@images/events/magento.png";
import crocafeLogo from "@images/events/crocafe.jpg";
import sprykerLogo from "@images/events/spryker.png";

// Community URLs for JSON-LD
const communityUrls: Record<string, string> = {
  "Mambo/Joomla!": "https://www.joomla.org/",
  "Dutchento / Meet Magento Netherlands": "https://www.dutchento.org/",
  "CRO.CAFE": "https://cro.cafe/",
  Spryker: "https://spryker.com/",
};

// Community data
const communities = [
  {
    name: "Mambo/Joomla!",
    period: "2004-2009",
    role: "Translator, local community organizer (virtual and in-person)",
    roleType: "volunteer",
    context: "Open source CMS community",
    logo: joomlaLogo,
    description:
      "My first community experience. I contributed to the Mambo open source CMS project with (Dutch) translations, then followed the community fork that became Joomla! in 2005. This was my introduction to how open source communities work: the governance challenges, the passion, and how open source communities can build software that competes with commercial products.",
    achievements: [
      "Early contributor to what became one of the world's most popular CMS platforms",
      "Learned open source community dynamics firsthand",
      "Ran the local Dutch community portal, organized meetups and the yearly Joomladays conference.",
    ],
  },
  {
    name: "Dutchento / Meet Magento Netherlands",
    period: "2008-2021",
    role: "Founder, Association Board Member",
    roleType: "volunteer",
    context: "13 years",
    logo: magentoLogo,
    description:
      "I founded the Dutch community for the Magento e-commerce platform when there was no local hub for developers and merchants. What started as local meetups grew into Meet Magento Netherlands: an annual event scaling to 600+ attendees that sparked a global event series in other countries.",
    achievements: [
      "Scaled from local meetups to 600+ annual attendees",
      "Organized 11 editions of Meet Magento Netherlands",
      "Received Community Builder Award from eBay CEO John Donahoe",
      "Co-created a model replicated by Meet Magento events worldwide",
      "Founding Board Member of the global Magento Association",
    ],
  },
  {
    name: "CRO.CAFE",
    period: "2018-2022",
    role: "Creator & Host",
    roleType: "professional",
    context: "4 years",
    logo: crocafeLogo,
    description:
      "I noticed the conversion optimization community lacked a consistent interview-format podcast where practitioners shared how they actually worked. I created CRO.CAFE as a side project where I had 1-on-1 conversations with people from agencies, brands, and tool vendors about their real work. The show attracted sponsorship and spun off into Dutch, Spanish, and German versions hosted by other specialists.",
    achievements: [
      "Produced 200+ episodes",
      "Received Experimentation Culture Award for community impact",
      "Expanded to four languages with other hosts",
      "Built sustainable sponsorship model",
      "Created multi-language network reaching global CRO community",
    ],
  },
  {
    name: "Spryker",
    period: "2021-2025",
    role: "Employee (Senior Director, Global Business & Technology Evangelist)",
    roleType: "professional",
    context: "4+ years",
    logo: sprykerLogo,
    // White wordmark — needs a dark field to be visible in both themes.
    logoBg: "bg-base-900",
    description:
      "Built the enterprise community function from scratch, serving 130+ B2B clients and their developer ecosystem. This was community building in a different context: enterprise software with no freemium tier, where community size is tied to sales rather than organic growth. Required different strategies: Customer Advisory Boards, MIT-licensed module ecosystems, and structures that translate community intelligence into product decisions.",
    achievements: [
      "Built community platform serving 130+ enterprise accounts with 3-person team",
      "Launched Customer Advisory Board connecting enterprise clients directly to product teams",
      "Established MIT-licensed module ecosystem, creating a vendor-independent innovation layer",
      "Community-driven initiatives now influence 25% of product roadmap decisions",
      "Multiple hackathon projects adopted into core product",
    ],
    quote:
      "Unlike consumer communities where you can grow through free trials, enterprise B2B community requires different strategies. I learned to create value for a smaller, higher-stakes audience.",
  },
];
---

<BaseLayout
  title="Community Building | Guido X Jansen"
  description="Track record of building developer and technical communities from zero: Joomla!, Dutchento/Meet Magento, CRO.CAFE, and Spryker. Community Builder Award recipient."
  type="communities"
  communities={communities.map((c) => ({
    name: c.name,
    url: communityUrls[c.name],
  }))}
>
  <div class="home communities-page">
    <!-- Hero -->
    <section
      class="relative z-10 pt-[clamp(4.5rem,9vw,7rem)] pb-[clamp(2rem,5vw,4rem)]"
    >
      <div class="max-w-[60ch]">
        <span class="hand-note">where I've built</span>
        <h1
          class="font-display mt-1 mb-4 text-[clamp(2.2rem,5vw,3.2rem)] leading-[1.05] font-black tracking-[-0.03em]"
        >
          Building communities from zero
        </h1>
        <p class="text-base-600 dark:text-base-400 text-lg leading-relaxed">
          I've built community functions from scratch multiple times, across
          very different contexts.
        </p>
      </div>
    </section>

    <!-- Communities -->
    <section class="relative z-10 pb-[clamp(3rem,7vw,5.5rem)]">
      <div class="flex flex-col gap-[clamp(3rem,7vw,5rem)]">
        {
          communities.map((community, index) => (
            <div class="grid items-center gap-8 md:grid-cols-2 md:gap-12">
              <div class={index % 2 === 1 ? "md:order-2" : ""}>
                <div
                  class={`border-base-200 dark:border-base-800 flex aspect-video min-h-[200px] items-center justify-center rounded-2xl border p-8 ${community.logoBg ?? "bg-white"}`}
                >
                  <Image
                    src={community.logo}
                    alt={`${community.name} logo`}
                    class="max-h-[120px] w-auto object-contain"
                    height={120}
                  />
                </div>
              </div>

              <div class={index % 2 === 1 ? "md:order-1" : ""}>
                <div class="flex flex-wrap items-center gap-3">
                  <span class="chip chip--plain">{community.period}</span>
                  <span class="text-base-500 text-sm">{community.context}</span>
                </div>

                <h2 class="font-display mt-3 text-[clamp(1.6rem,3vw,2.1rem)] font-extrabold tracking-[-0.02em]">
                  {community.name}
                </h2>
                <p class="text-primary-600 dark:text-primary-400 mt-1 font-semibold">
                  {community.role}
                </p>

                <p class="text-base-600 dark:text-base-400 mt-3 leading-relaxed">
                  {community.description}
                </p>

                <div class="mt-5">
                  <h3 class="text-base-500 mb-3 text-xs font-bold tracking-[0.08em] uppercase">
                    Key achievements
                  </h3>
                  <ul class="flex flex-col gap-2">
                    {community.achievements.map((achievement) => (
                      <li class="text-base-600 dark:text-base-400 flex items-start gap-2.5">
                        <Icon
                          name="tabler/outline/check"
                          class="text-primary-600 dark:text-primary-400 mt-0.5 size-5 shrink-0"
                          aria-hidden="true"
                        />
                        <span>{achievement}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                {community.quote && (
                  <blockquote class="border-primary-600/30 dark:border-primary-400/30 text-base-700 dark:text-base-300 mt-6 border-l-4 pl-4 italic">
                    "{community.quote}"
                  </blockquote>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- CTA -->
    <section class="relative z-10 pb-[clamp(3rem,7vw,5.5rem)]">
      <div
        class="border-base-200 dark:border-base-800 from-gold/15 rounded-3xl border bg-gradient-to-br to-transparent p-[clamp(1.5rem,4vw,3rem)] text-center"
      >
        <div class="mx-auto max-w-2xl">
          <span class="eyebrow">What's next</span>
          <h2
            class="font-display my-2 text-[clamp(1.9rem,3.6vw,2.7rem)] font-black tracking-[-0.03em]"
          >
            Let's build the next one
          </h2>
          <p
            class="text-base-700 dark:text-base-300 mt-3 text-lg leading-relaxed"
          >
            I'm interested in technical ecosystems that can become genuine
            growth engines. Particularly open source, AI, automation, commerce
            and privacy-focused organizations.
          </p>
          <a
            href="/retainer/"
            class="bg-primary-600 hover:bg-primary-700 dark:bg-primary-500 dark:hover:bg-primary-400 font-display mt-6 inline-flex items-center gap-1.5 rounded-full px-6 py-3 text-sm font-bold text-white transition"
          >
            Work with me <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
