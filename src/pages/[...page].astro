---
import { type CollectionEntry, getCollection, render } from "astro:content";

// layout
import BaseLayout from "@layouts/BaseLayout.astro";

// components
import ExternalLink from "@components/MarkdownComponents/ExternalLink.astro";

export async function getStaticPaths() {
  const otherPages: CollectionEntry<"otherPages">[] = await getCollection(
    "otherPages",
    ({ data }) => {
      // filter out draft pages
      return data.draft !== true;
    },
  );

  // Note: otherPages don't have language-specific versions, so no need to filter by locale
  return otherPages.map((page) => ({
    params: { page: page.id },
    props: page,
  }));
}

type Props = CollectionEntry<"otherPages">;
const page = Astro.props;

// Ensure we have valid page data
if (!page?.data) {
  return new Response("Page not found", {
    status: 404,
    statusText: "Not Found",
  });
}

const { title, description } = page.data;
const { Content } = await render(page);
---

<BaseLayout title={title} description={description}>
  <div class="home other-page">
    <section
      class="relative z-10 pt-[clamp(4.5rem,9vw,7rem)] pb-[clamp(2rem,5vw,4rem)]"
    >
      <div class="mx-auto max-w-3xl text-center">
        <h1
          class="font-display mt-2 mb-4 text-[clamp(2.2rem,5vw,3.2rem)] leading-[1.05] font-black tracking-[-0.03em]"
        >
          {title}
        </h1>
      </div>
    </section>

    <section class="relative z-10 pb-[clamp(3rem,7vw,5.5rem)]">
      <div class="mx-auto max-w-3xl">
        <div class="prose dark:prose-invert max-w-none">
          <Content components={{ a: ExternalLink }} />
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
