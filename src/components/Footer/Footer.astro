---
import { getRelativeLocaleUrl } from "astro:i18n";

// components
import SiteLogo from "@components/SiteLogo/SiteLogo.astro";
import SocialLinks from "@components/SocialLinks/SocialLinks.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData } from "@js/translationUtils";

// data
const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);

const today = new Date();

const rel = (path: string) => getRelativeLocaleUrl(currLocale, path);

// Footer link columns. Every kept page has a home here.
const columns: {
  title: string;
  links: { text: string; href: string; newTab?: boolean }[];
}[] = [
  {
    title: "Creations",
    links: [
      { text: "Articles", href: rel("/post") },
      { text: "Podcasts", href: rel("/podcasts") },
      { text: "Presentations", href: rel("/presentations") },
      { text: "Projects", href: rel("/projects") },
      { text: "Communities", href: rel("/communities") },
    ],
  },
  {
    title: "Work with me",
    links: [
      { text: "Retainer", href: rel("/retainer") },
      { text: "Speak at your event", href: rel("/speaker") },
      { text: "Training", href: rel("/training") },
      { text: "CV", href: rel("/cv") },
      { text: "Contact", href: rel("/contact") },
    ],
  },
  {
    title: "More",
    links: [
      { text: "About", href: rel("/about") },
      { text: "Events", href: rel("/events") },
      { text: "Ask me anything", href: rel("/ama") },
      { text: "Press & Media", href: rel("/press") },
      { text: "Newsletter", href: rel("/newsletter") },
      { text: "Privacy", href: rel("/privacy") },
    ],
  },
];
---

<footer
  class="border-base-200/60 bg-base-50/60 dark:border-base-800/60 dark:bg-base-950/40 relative z-10 mt-24 overflow-x-clip border-t pt-16 pb-12 backdrop-blur-sm"
  role="contentinfo"
  aria-label="Site footer"
>
  <div class="site-container px-4">
    <div
      class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-[1.5fr_1fr_1fr_1fr]"
    >
      <!-- Brand column -->
      <div class="flex flex-col gap-4">
        <SiteLogo />
        <p
          class="text-base-600 dark:text-base-400 max-w-sm text-sm leading-relaxed"
        >
          For 20+ years I've helped tech teams turn developer &amp; customer
          intelligence into product strategy, grounded in cognitive psychology
          and a habit of testing my assumptions. I help build communities, and
          the teams that run them.
        </p>
        <SocialLinks location="footer" context="footer" class="mt-1" />
      </div>

      <!-- Link columns -->
      {
        columns.map((col) => (
          <nav class="flex flex-col gap-1" aria-label={`Footer: ${col.title}`}>
            <h2 class="text-base-500 dark:text-base-500 mb-1 text-xs font-bold tracking-[0.08em] uppercase">
              {col.title}
            </h2>
            {col.links.map((link) => (
              <a
                href={link.href}
                target={link.newTab ? "_blank" : undefined}
                rel={link.newTab ? "noopener noreferrer" : undefined}
                class="text-base-600 hover:text-primary-600 dark:text-base-400 dark:hover:text-primary-400 focus:ring-primary-500 -mx-1 rounded-sm px-1 py-1.5 text-[0.95rem] transition focus:ring-2 focus:outline-hidden"
              >
                {link.text}
                {link.newTab && <span class="sr-only">(opens in new tab)</span>}
              </a>
            ))}
          </nav>
        ))
      }
    </div>

    <!-- Bottom bar -->
    <div
      class="border-base-200/60 dark:border-base-800/60 text-base-500 dark:text-base-500 mt-12 flex flex-col gap-2 border-t pt-6 text-sm sm:flex-row sm:items-center sm:justify-between"
    >
      <p>
        &copy; {today.getFullYear()}{" "}{siteData.name}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
