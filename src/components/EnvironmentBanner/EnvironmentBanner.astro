---
// src/components/EnvironmentBanner/EnvironmentBanner.astro
import { CONFIG } from "src/config.ts";
import { Icon } from "astro-icon/components";

const isProduction = CONFIG.ALLOW_INDEXING;
---

{
  !isProduction && (
    <div
      class="environment-banner"
      role="alert"
      aria-atomic="true"
      aria-live="polite"
    >
      <div class="banner-content">
        <Icon
          name="tabler/alert-triangle"
          class="h-4 w-4"
          aria-hidden="true"
          role="presentation"
        />
        <span>Preview Environment</span>
        <button
          type="button"
          class="banner-close"
          aria-label="Dismiss preview environment notification"
        >
          <Icon
            name="tabler/x"
            class="h-4 w-4"
            aria-hidden="true"
            role="presentation"
          />
        </button>
      </div>
    </div>
  )
}

<style>
  .environment-banner {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background-color: #eb6f92; /* Rosé Pine love */
    color: #191724; /* Rosé Pine base — dark text passes WCAG AA (6.4:1) on love */
    text-align: center;
    z-index: 9999;
    font-weight: 600;
    font-size: 0.875rem;
    line-height: 1.25rem;
  }

  .banner-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    max-width: 100%;
    margin: 0 auto;
  }

  .banner-close {
    position: absolute;
    right: 1rem;
    padding: 0.25rem;
    color: #191724;
    border-radius: 0.25rem;
    transition: background-color 0.2s;
  }

  .banner-close:hover {
    background-color: rgba(25, 23, 36, 0.12);
  }

  .banner-close:focus {
    outline: 2px solid #191724;
    outline-offset: 2px;
  }

  /* prefers-contrast: more — lighten the pink so the dark text contrast
     ratio increases further (the point of this media query). */
  @media (prefers-contrast: more) {
    .environment-banner {
      background-color: #fde4ea;
    }
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .banner-close {
      transition: none;
    }
  }
</style>

<script>
  function initBanner() {
    const banner = document.querySelector(
      ".environment-banner",
    ) as HTMLElement | null;
    const closeButton = banner?.querySelector(
      ".banner-close",
    ) as HTMLElement | null;

    if (banner && closeButton) {
      closeButton.addEventListener("click", () => {
        banner.style.display = "none";
        // Store dismissal in session storage
        sessionStorage.setItem("previewBannerDismissed", "true");
      });

      // Handle keyboard events
      closeButton.addEventListener("keydown", (event) => {
        const e = event as KeyboardEvent;
        if (e.key === "Enter" || e.key === " ") {
          event.preventDefault();
          closeButton.click();
        }
      });

      // Check if banner was previously dismissed
      if (sessionStorage.getItem("previewBannerDismissed") === "true") {
        banner.style.display = "none";
      }
    }
  }

  // Initialize on page load
  initBanner();

  // Re-initialize after view transitions
  document.addEventListener("astro:after-swap", initBanner);
</script>
