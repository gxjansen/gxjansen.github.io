---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

export interface Props {
  presentation: CollectionEntry<"presentations">;
}

const { presentation } = Astro.props;
const { title, duration, intendedAudience, isWorkshop, image } =
  presentation.data;
const href = `/presentations/${presentation.id}/`;
---

<article
  class="group bg-base-50 dark:bg-base-900 border-base-200 dark:border-base-800 reveal relative flex flex-col overflow-hidden rounded-2xl border transition hover:-translate-y-0.5 hover:shadow-lg"
>
  {
    image && (
      <Image
        src={image}
        alt={title || ""}
        width={1600}
        height={900}
        class="aspect-video w-full object-cover transition duration-300 group-hover:scale-[1.03]"
      />
    )
  }
  <div class="flex flex-1 flex-col p-5">
    <div class="mb-3 flex flex-wrap gap-2">
      {duration && <span class="chip chip--plain">{duration}</span>}
      {isWorkshop && <span class="chip">Workshop</span>}
    </div>
    <h3 class="font-display text-[1.15rem] leading-snug font-extrabold">
      <a
        href={href}
        class="hover:text-primary-600 dark:hover:text-primary-400 after:absolute after:inset-0 after:content-['']"
      >
        {title}
      </a>
    </h3>
    {
      intendedAudience && (
        <p class="text-base-600 dark:text-base-400 mt-2 text-[0.92rem] leading-relaxed">
          <span class="font-semibold">For:</span> {intendedAudience}
        </p>
      )
    }
    <span
      class="text-primary-600 dark:text-primary-400 font-display mt-4 inline-flex items-center gap-1.5 text-sm font-bold"
    >
      View presentation <span aria-hidden="true">→</span>
    </span>
  </div>
</article>
