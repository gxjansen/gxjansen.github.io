---
/**
 * * Hero with background blobs and side image
 *
 * There is a commented out "awards" section below in case you want that
 */
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import SocialLinks from "@components/SocialLinks/SocialLinks.astro";

// components
import Button from "@components/Button/Button.astro";
import Badge from "@components/Badge/Badge.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { useTranslations } from "@js/translationUtils";

// images
import heroImage from "@assets/images/guido-couch.jpg";

const currLocale = getLocaleFromUrl(Astro.url);
const t = useTranslations(currLocale);
---

<section
  id="hero-side"
  aria-labelledby="hero-heading"
  class="mt-20 overflow-clip"
>
  <div class="relative pt-10 pb-20 md:py-28" role="presentation">
    <div class="relative z-10 flex flex-wrap xl:items-center">
      <div class="mb-16 w-full md:mb-0 md:w-1/2">
        <Badge>Community Builder</Badge>
        <div class="flex flex-col gap-4">
          <h1
            id="hero-heading"
            class="text-base-900 dark:text-base-100 leading-normal font-bold tracking-normal text-balance"
            style="font-size: clamp(1.875rem, 1.25rem + 2.5vw, 3rem); line-height: 1.2;"
          >
            {t("hero_text")}
          </h1>
        </div>
        <div
          class="description text-base-700 dark:text-base-300 mb-8 text-lg leading-relaxed text-pretty lg:text-xl [&>br+br]:mb-4 [&>br+br]:block"
        >
          <Fragment
            set:html={t("hero_description")
              .replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>")
              .replace(/\n\n/g, "<br><br>")
              .replace(/\n/g, "<br>")}
          />
        </div>
        <div
          class="mt-6 flex flex-wrap gap-4"
          role="group"
          aria-label="Call to action buttons"
        >
          <Button
            variant="primary"
            href="/retainer/"
            aria-label="Work with Guido on a community advisory engagement"
            class="focus:ring-primary-500 min-h-[44px] min-w-[44px] focus:ring-2 focus:ring-offset-2 focus:outline-hidden"
            umamiEvent="cta-click"
            umamiEventTarget="work-with-me-hero"
          >
            Work with me
          </Button>
          <Button
            variant="outline"
            href="/speaker/"
            aria-label="Invite Guido to speak at your event"
            class="focus:ring-primary-500 min-h-[44px] min-w-[44px] focus:ring-2 focus:ring-offset-2 focus:outline-hidden"
            umamiEvent="cta-click"
            umamiEventTarget="invite-to-speak-hero"
          >
            Invite me to speak
          </Button>
        </div>
        <!-- Socials -->
        <div class="relative">
          <div class="relative z-20">
            <SocialLinks class="mt-6" location="hero" context="hero" />
          </div>
        </div>
      </div>
      <div class="w-full md:w-1/2 md:pl-6 lg:pl-8">
        <div class="relative mx-auto max-w-max md:mr-0">
          <Icon
            name="atlas/circle3"
            class="text-accent-4 absolute -top-12 -left-14 z-10 w-28"
            aria-hidden="true"
            role="presentation"
          />
          <Icon
            name="atlas/dots3"
            class="text-accent-2 absolute -right-7 -bottom-8 z-10 w-28"
            aria-hidden="true"
            role="presentation"
          />
          <div
            class="rounded-7xl relative overflow-hidden rounded-2xl"
            role="img"
            aria-label="Profile photo of Guido Jansen"
          >
            <Image
              src={heroImage}
              class="h-auto min-w-full object-cover"
              alt="Guido Jansen, a CRO and UX specialist, sitting casually on a modern grey office couch with a laptop. He's wearing casual business attire and has a welcoming expression, representing his approachable consulting style."
              loading="eager"
              fetchpriority="high"
              widths={[360, 600, 768, 1024, 1200]}
              sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 500px"
              quality={85}
              format="webp"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
