---
import { getRelativeLocaleUrl } from "astro:i18n";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";

interface Props {
  /** Render the dot in gold for pine/dark surfaces (avatar tiles, pine cards). */
  onPine?: boolean;
  class?: string;
}

const { onPine = false, class: className } = Astro.props as Props;

const currLocale = getLocaleFromUrl(Astro.url);

/**
 * The gui.do wordmark — the brand mark for the site & content.
 * The dot is a real SLD·TLD separator: pine by default, gold on a pine
 * surface. Never crop to a dangling "g." or ".do".
 */
const dotColor = onPine
  ? "text-gold"
  : "text-primary-600 dark:text-primary-400";
---

<a
  class:list={[
    "primary-focus group font-display text-base-900 dark:text-base-100 inline-flex items-baseline text-[1.3rem] leading-none font-black tracking-[-0.035em] no-underline",
    onPine && "text-base-50",
    className,
  ]}
  href={getRelativeLocaleUrl(currLocale)}
  aria-label="gui.do — home"
>
  <span aria-hidden="true">gui</span>
  <span
    class:list={[
      "inline-block text-[1.15em] transition-transform duration-200 ease-out group-hover:scale-[1.4] motion-reduce:transition-none motion-reduce:group-hover:scale-100",
      dotColor,
    ]}
    aria-hidden="true">.</span
  >
  <span aria-hidden="true">do</span>
</a>
