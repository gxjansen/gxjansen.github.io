---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

interface Props {
  name: string;
  description: string;
  mainImage: string;
  link?: string;
  iconBgColor: string;
  license?: string;
  tagline?: string;
  githubUrl?: string;
}

const {
  name,
  description,
  mainImage,
  link,
  iconBgColor,
  license,
  tagline,
  githubUrl,
} = Astro.props;
---

<article
  class="group bg-base-50 dark:bg-base-900 border-base-200 dark:border-base-800 reveal rounded-2xl border p-6 transition hover:shadow-lg sm:p-7"
>
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-[auto_1fr] sm:items-start">
    <div
      class={`${iconBgColor} flex size-20 shrink-0 items-center justify-center rounded-2xl transition-transform duration-300 group-hover:scale-105`}
    >
      {
        mainImage.startsWith("/") ? (
          <Image
            src={mainImage}
            alt={`${name} icon`}
            width={48}
            height={48}
            class="size-12"
          />
        ) : (
          <Icon
            name={mainImage}
            class="size-12 text-white"
            aria-hidden="true"
          />
        )
      }
    </div>

    <div class="min-w-0">
      <h2 class="font-display text-[1.4rem] font-extrabold tracking-[-0.02em]">
        {
          link ? (
            <a
              href={link}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-primary-600 dark:hover:text-primary-400 transition"
            >
              {name}
            </a>
          ) : (
            name
          )
        }
      </h2>
      {
        (tagline || license) && (
          <p class="text-primary-600 dark:text-primary-400 mt-1 text-sm font-semibold">
            {tagline || `License: ${license}`}
          </p>
        )
      }
      <div
        class="prose dark:prose-invert text-base-700 dark:text-base-300 mt-3 max-w-none"
        set:html={description}
      />

      <div class="mt-5 flex flex-wrap items-center gap-3">
        {
          link && (
            <a
              href={link}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-primary-600 hover:bg-primary-700 dark:bg-primary-500 dark:hover:bg-primary-400 font-display inline-flex items-center gap-1.5 rounded-full px-5 py-2.5 text-sm font-bold text-white transition"
            >
              View project <span aria-hidden="true">→</span>
              <span class="sr-only">View {name} project</span>
            </a>
          )
        }
        {
          githubUrl && (
            <a
              href={githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="border-base-300 hover:border-primary-600 dark:border-base-700 dark:hover:border-primary-400 font-display inline-flex items-center gap-2 rounded-full border px-5 py-2.5 text-sm font-bold transition"
            >
              <Icon
                name="tabler/filled/brand-github"
                class="size-5"
                aria-hidden="true"
              />
              GitHub
            </a>
          )
        }
      </div>
    </div>
  </div>
</article>
