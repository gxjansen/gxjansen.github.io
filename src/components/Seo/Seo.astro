---
import { getImage } from "astro:assets";
import { type CollectionEntry } from "astro:content";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData } from "@js/translationUtils";

// data
const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);

// component import
import jsonLDGenerator from "@js/jsonLD";
import type { EventData, PresentationData, CommunityData } from "@js/jsonLD";

interface BaseProps {
  title: string;
  description: string;
  noindex?: boolean;
}

interface GenProps extends BaseProps {
  type: "general";
  image?: ImageMetadata;
}

interface BlogProps extends BaseProps {
  type: "blog";
  image?: ImageMetadata;
  authors?: CollectionEntry<"authors">[];
  postFrontmatter?: CollectionEntry<"post">["data"];
}

interface EventProps extends BaseProps {
  type: "event";
  image?: ImageMetadata;
  event: EventData;
}

interface EventListProps extends BaseProps {
  type: "eventList";
  image?: ImageMetadata;
  events: EventData[];
}

interface PresentationProps extends BaseProps {
  type: "presentation";
  image?: ImageMetadata;
  presentation: PresentationData;
  slug: string;
}

interface PresentationListProps extends BaseProps {
  type: "presentationList";
  image?: ImageMetadata;
  presentations: PresentationData[];
  slugs: string[];
}

interface CommunitiesProps extends BaseProps {
  type: "communities";
  image?: ImageMetadata;
  communities: CommunityData[];
}

type SeoProps =
  | GenProps
  | BlogProps
  | EventProps
  | EventListProps
  | PresentationProps
  | PresentationListProps
  | CommunitiesProps;

const {
  type,
  title,
  description,
  image,
  noindex = false,
} = Astro.props as SeoProps;

let optimizedImage: any;
let jsonLD: any;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

// Process the custom OG image up-front so any page type can use it.
// (Previously only blog pages did this, which silently dropped the
// override for general pages.) Only run getImage on real ImageMetadata —
// some callers (e.g. presentations) pass a URL/string with `as any`.
const isImageMetadata =
  image && typeof image === "object" && "src" in image && "format" in image;
if (isImageMetadata) {
  // og:image must be PNG/JPEG, not WebP. Many social/link-preview scrapers
  // (X/Twitter, plus various embed tools) silently fail to render WebP
  // og:image, leaving a blank card. JPEG keeps photographic hero images
  // small while staying universally supported.
  optimizedImage = await getImage({
    src: image,
    format: "jpeg",
    quality: "high",
    width: 1200,
    height: 630,
    fit: "cover",
  });
}

// if this is a blog page we do things differently
if (type === "blog") {
  const { authors = [], postFrontmatter } = Astro.props as BlogProps;

  jsonLD = jsonLDGenerator({
    type: "blog",
    postFrontmatter: postFrontmatter as any,
    image: optimizedImage,
    authors: authors as any,
    canonicalUrl: canonicalUrl,
  });
} else if (type === "event") {
  const { event } = Astro.props as EventProps;
  jsonLD = jsonLDGenerator({
    type: "event",
    event,
    canonicalUrl,
  });
} else if (type === "eventList") {
  const { events } = Astro.props as EventListProps;
  jsonLD = jsonLDGenerator({
    type: "eventList",
    events,
    canonicalUrl,
  });
} else if (type === "presentation") {
  const { presentation, slug } = Astro.props as PresentationProps;
  jsonLD = jsonLDGenerator({
    type: "presentation",
    presentation,
    slug,
    canonicalUrl,
  });
} else if (type === "presentationList") {
  const { presentations, slugs } = Astro.props as PresentationListProps;
  jsonLD = jsonLDGenerator({
    type: "presentationList",
    presentations,
    slugs,
    canonicalUrl,
  });
} else if (type === "communities") {
  const { communities } = Astro.props as CommunitiesProps;
  jsonLD = jsonLDGenerator({
    type: "communities",
    communities,
    canonicalUrl,
  });
} else {
  // for general pages
  jsonLD = jsonLDGenerator({
    type: "general",
  });
}

// Ensure we have an absolute URL for the image
const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, "") : "";
const imageUrl = optimizedImage
  ? new URL(optimizedImage.src, siteUrl).toString()
  : new URL(siteData.defaultImage.src, siteUrl).toString();

// Helper function to safely format dates
const formatDate = (date: Date | undefined) => {
  return date instanceof Date ? date.toISOString() : undefined;
};
---

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex,nofollow" />}
<link rel="canonical" href={canonicalUrl.toString()} />

<!-- Language and Accessibility Meta Tags -->
<meta http-equiv="content-language" content={currLocale} />
<meta name="language" content={currLocale} />
<meta name="accessibility" content="WCAG2.1,AAA" />
<meta name="rating" content="General" />

<!-- Image Accessibility -->
<meta property="og:image:alt" content={description} />
<meta name="twitter:image:alt" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type === "blog" ? "article" : "website"} />
<meta property="og:locale" content={currLocale} />
{
  type === "blog" && (
    <>
      {formatDate(Astro.props.postFrontmatter?.publishDate) && (
        <meta
          property="article:published_time"
          content={formatDate(Astro.props.postFrontmatter?.publishDate)}
        />
      )}
      {formatDate(Astro.props.postFrontmatter?.updateDate) && (
        <meta
          property="article:modified_time"
          content={formatDate(Astro.props.postFrontmatter?.updateDate)}
        />
      )}
      <meta property="article:author" content={siteData.author.name} />
      {Astro.props.postFrontmatter?.tags?.map((tag: string) => (
        <meta property="article:tag" content={tag} />
      ))}
    </>
  )
}
<meta property="og:url" content={canonicalUrl.toString()} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl} />
<meta property="og:site_name" content={siteData.title} />

<!-- Additional OpenGraph tags for better LinkedIn support -->
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalUrl.toString()} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageUrl} />
<!--
  twitter:site / twitter:creator removed — Guido no longer maintains a
  Twitter/X presence. The other twitter:* tags stay because LinkedIn, Slack,
  and other consumers still read them for link-preview rendering.
-->

<!-- JSON LD -->
<Fragment set:html={jsonLD} />

<!-- Additional Accessibility Meta Tags -->
{
  type === "blog" && (
    <>
      <meta
        name="author"
        content={
          Astro.props.authors
            ?.map((author: { data: { name: string } }) => author.data.name)
            .join(", ") || siteData.author.name
        }
      />
      {formatDate(Astro.props.postFrontmatter?.publishDate) && (
        <meta
          name="date"
          content={formatDate(Astro.props.postFrontmatter?.publishDate)}
        />
      )}
      {formatDate(Astro.props.postFrontmatter?.updateDate) && (
        <meta
          name="last-modified"
          content={formatDate(Astro.props.postFrontmatter?.updateDate)}
        />
      )}
    </>
  )
}
